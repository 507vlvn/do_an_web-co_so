@model do_an.Models.DanhMucSanPham
@{
    ViewData["Title"] = "Sửa Danh Mục Sản Phẩm";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4"><i class="bi bi-pencil-square text-brand me-2"></i>Sửa Danh Mục</h5>

                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="TenDanhMuc" class="form-label fw-semibold"></label>
                        <input asp-for="TenDanhMuc" class="form-control rounded-3" />
                        <span asp-validation-for="TenDanhMuc" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MoTa" class="form-label fw-semibold"></label>
                        <textarea asp-for="MoTa" class="form-control rounded-3" rows="3"></textarea>
                        <span asp-validation-for="MoTa" class="text-danger small"></span>
                    </div>

                    <div class="mb-3 form-check form-switch">
                        <input asp-for="KichHoat" class="form-check-input" />
                        <label asp-for="KichHoat" class="form-check-label fw-semibold"></label>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-brand rounded-pill px-4">
                            <i class="bi bi-check-lg me-1"></i> Cập nhật
                        </button>
                        <a asp-action="Index" class="btn btn-light rounded-pill px-4">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
