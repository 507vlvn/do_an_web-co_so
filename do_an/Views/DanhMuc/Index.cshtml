@model IEnumerable<do_an.Models.DanhMucSanPham>
@{
    ViewData["Title"] = "Quản lý Danh Mục Sản Phẩm";
    var dtCountPerDm = ViewBag.DtCountPerDm as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1 text-dark"><i class="bi bi-grid-fill text-brand me-2"></i>Quản Lý Danh Mục Sản Phẩm</h4>
        <p class="text-muted small mb-0">Thêm, sửa, xóa các danh mục sản phẩm trên website</p>
    </div>
    <a asp-action="Create" class="btn btn-brand px-4 rounded-pill">
        <i class="bi bi-plus-circle me-1"></i> Thêm Danh Mục Mới
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-4" style="background:#f8fafc;color:#64748b;font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;font-weight:700">ID</th>
                    <th style="background:#f8fafc;color:#64748b;font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;font-weight:700">Tên Danh Mục</th>
                    <th style="background:#f8fafc;color:#64748b;font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;font-weight:700">Mô Tả</th>
                    <th class="text-center" style="background:#f8fafc;color:#64748b;font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;font-weight:700">Trạng Thái</th>
                    <th class="text-center" style="background:#f8fafc;color:#64748b;font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;font-weight:700">Sản Phẩm</th>
                    <th class="pe-4 text-center" style="background:#f8fafc;color:#64748b;font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;font-weight:700">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            Chưa có danh mục nào.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    var dtCount = dtCountPerDm.GetValueOrDefault(item.Id, 0);
                    var totalCount = item.SanPhams.Count + dtCount;

                    <tr>
                        <td class="ps-4 fw-semibold text-muted">#@item.Id</td>
                        <td>
                            <span class="fw-semibold">@item.TenDanhMuc</span>
                        </td>
                        <td class="text-muted small" style="max-width:250px;">
                            @(item.MoTa ?? "—")
                        </td>
                        <td class="text-center">
                            @if (item.KichHoat)
                            {
                                <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">Kích hoạt</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary px-3 py-2 rounded-pill">Ẩn</span>
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark border px-3 py-2 rounded-pill">
                                @totalCount sản phẩm
                            </span>
                            @if (dtCount > 0)
                            {
                                <div class="text-muted x-small mt-1">
                                    <i class="bi bi-clipboard2-pulse"></i> @dtCount đơn thuốc
                                </div>
                            }
                        </td>
                        <td class="pe-4 text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary border-0 me-1" title="Sửa">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            @if (totalCount == 0)
                            {
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Bạn chắc chắn muốn xóa danh mục này?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger border-0" title="Xóa">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-secondary border-0" disabled title="Không thể xóa – đang có sản phẩm">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
