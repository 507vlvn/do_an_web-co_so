@{
    ViewData["Title"] = "Không Có Quyền Truy Cập";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="card shadow-sm border-warning">
            <div class="card-body py-5">
                <i class="bi bi-shield-exclamation text-warning" style="font-size: 4rem;"></i>
                <h2 class="fw-bold mt-3 text-warning">Không Có Quyền Truy Cập</h2>
                <p class="text-muted mt-2">
                    Bạn không có quyền truy cập trang này.<br />
                    Vui lòng liên hệ Quản Trị Viên.
                </p>
                <div class="d-flex gap-2 justify-content-center mt-4">
                    <a asp-controller="Store" asp-action="Index" class="btn btn-success px-4 rounded-pill">
                        <i class="bi bi-shop me-1"></i> Quay lại Cửa Hàng
                    </a>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-secondary px-4 rounded-pill">
                            <i class="bi bi-box-arrow-right me-1"></i> Đăng Xuất
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
