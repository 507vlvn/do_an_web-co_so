@model do_an.Models.DonHang
@{
    ViewData["Title"] = "Thanh toán online";
    Layout = "_StoreLayout";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="bg-white rounded-3 shadow p-5 text-center">
            <div class="mb-4">
                <i class="bi bi-credit-card-2-front text-primary" style="font-size:4rem"></i>
            </div>
            <h4 class="fw-bold mb-1">Thanh toán online</h4>
            <p class="text-muted mb-4">Mã đơn hàng: <strong class="text-primary">@Model.MaDonHang</strong></p>

            <div class="bg-light rounded p-4 mb-4">
                <div class="d-flex justify-content-between mb-2">
                    <span>Số tiền</span>
                    <strong class="text-danger fs-5">@Model.TongThanhToan.ToString("N0")đ</strong>
                </div>
                <div class="d-flex justify-content-between text-muted small">
                    <span>Người nhận</span>
                    <span>@Model.HoTenNguoiNhan</span>
                </div>
            </div>

            @* QR code giả lập *@
            <div class="border border-2 border-primary rounded p-3 mb-4 d-inline-block">
                <div style="width:150px;height:150px;background:repeating-linear-gradient(45deg,#0d6efd,#0d6efd 2px,#fff 2px,#fff 8px);
                            margin:0 auto;border-radius:4px;display:flex;align-items:center;justify-content:center;">
                    <span class="text-white fw-bold">QR</span>
                </div>
                <p class="small text-muted mt-2 mb-0">Quét mã để thanh toán (giả lập)</p>
            </div>

            <form asp-action="XacNhanThanhToan" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="donHangId" value="@Model.Id" />
                <button type="submit" class="btn btn-success btn-lg w-100 fw-bold">
                    <i class="bi bi-check-circle me-2"></i>Xác nhận đã thanh toán
                </button>
            </form>
            <a asp-action="DatHangThanhCong" asp-route-donHangId="@Model.Id"
               class="btn btn-link text-muted mt-2">Bỏ qua, thanh toán sau</a>
        </div>
    </div>
</div>