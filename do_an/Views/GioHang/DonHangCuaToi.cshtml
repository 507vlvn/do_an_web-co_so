@model List<do_an.Models.DonHang>
@{
    ViewData["Title"] = "Lịch sử mua hàng";
    Layout = "_StoreLayout";
}

<div class="py-4">
    <div class="mb-5">
        <h1 class="display-6 fw-800 text-dark mb-1" style="letter-spacing: -2px;">Đơn hàng của tôi</h1>
        <p class="text-muted fw-600 mb-0">Theo dõi và quản lý các đơn hàng của bạn</p>
    </div>

    @* Filter Tabs *@
    <div class="bg-white rounded-pill shadow-sm border p-2 mb-5 d-inline-flex flex-wrap gap-2 overflow-auto max-w-100" style="border-color: #f1f5f9 !important;">
        @{
            (string label, string? val, string icon)[] tabs =
            [
                ("Tất cả",          null, "bi-grid"),
                ("Chờ thanh toán",  "0",  "bi-clock"),
                ("Đã thanh toán",   "1",  "bi-check-circle"),
                ("Đang chuẩn bị",   "2",  "bi-box-seam"),
                ("Đang giao",       "3",  "bi-truck"),
                ("Đã giao",         "4",  "bi-box-seam"),
                ("Đã hủy",          "5",  "bi-x-circle")
            ];
            var currentTab = ViewBag.TrangThai?.ToString();
        }
        @foreach (var (label, val, icon) in tabs)
        {
            <a class="btn btn-sm rounded-pill px-4 py-2 fw-800 transition-all d-flex align-items-center gap-2 @(currentTab == val ? "btn-brand text-white shadow-brand" : "btn-light text-muted border-0")"
               asp-action="DonHangCuaToi"
               asp-route-trangThai="@val">
                <i class="bi @icon"></i>
                <span class="text-nowrap">@label</span>
            </a>
        }
    </div>

    @if (Model.Count == 0)
    {
        <div class="text-center py-5 bg-white rounded-5 shadow-sm border border-dashed p-5" style="border-width: 2px;">
            <div class="mb-4 d-inline-block p-4 rounded-circle bg-light text-muted">
                <i class="bi bi-bag-x fs-1"></i>
            </div>
            <h3 class="fw-800 text-dark mb-3">Chưa có đơn hàng nào!</h3>
            <p class="text-muted mb-5 mx-auto fw-500" style="max-width: 400px;">
                Bạn chưa có đơn hàng nào trong mục này. Hãy tiếp tục khám phá các sản phẩm tuyệt vời của chúng tôi nhé.
            </p>
            <a asp-controller="Store" asp-action="Index" class="btn btn-brand rounded-pill px-5 py-3 fw-800 text-white shadow-brand">
                <i class="bi bi-shop me-2"></i> MUA SẮM NGAY
            </a>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var dh in Model)
            {
                var (badgeClass, badgeText, statusIcon) = dh.TrangThai switch
                {
                    do_an.Models.TrangThaiDonHang.ChoThanhToan => ("bg-warning-soft text-warning", "Chờ thanh toán", "bi-clock"),
                    do_an.Models.TrangThaiDonHang.DaThanhToan  => ("bg-brand-soft text-brand", "Đã thanh toán", "bi-check-circle"),
                    do_an.Models.TrangThaiDonHang.DangChuanBi  => ("bg-info-soft text-info", "Đang chuẩn bị", "bi-box"),
                    do_an.Models.TrangThaiDonHang.DangGiao     => ("bg-info-soft text-info", "Đang giao", "bi-truck"),
                    do_an.Models.TrangThaiDonHang.DaGiao       => ("bg-success-soft text-success", "Đã giao", "bi-check2-all"),
                    do_an.Models.TrangThaiDonHang.DaHuy        => ("bg-danger-soft text-danger", "Đã hủy", "bi-x-circle"),
                    _                                          => ("bg-light text-secondary", "Không xác định", "bi-question-circle")
                };

                <div class="bg-white rounded-5 shadow-sm border overflow-hidden order-card transition-all" style="border-color: #f1f5f9 !important;">
                    <div class="p-4 border-bottom d-flex flex-wrap justify-content-between align-items-center gap-3 bg-light bg-opacity-50">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-white rounded-4 px-3 py-2 border shadow-sm fw-800 text-brand">
                                #@dh.MaDonHang
                            </div>
                            <div class="text-muted small fw-600">
                                <i class="bi bi-calendar3 me-1"></i> @dh.NgayDat.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                             <span class="badge @badgeClass rounded-pill px-3 py-2 fw-800 d-flex align-items-center gap-2">
                                <i class="bi @statusIcon"></i>@badgeText
                            </span>
                        </div>
                    </div>

                    <div class="p-4 px-lg-5">
                        <div class="row align-items-center g-4">
                            <div class="col-lg-7">
                                <div class="space-y-2">
                                    <div class="d-flex align-items-start gap-3 text-muted small fw-600">
                                        <i class="bi bi-geo-alt text-brand"></i>
                                        <span>@dh.DiaChi</span>
                                    </div>
                                    <div class="d-flex align-items-center gap-3 text-muted small fw-600">
                                        <i class="bi bi-telephone text-brand"></i>
                                        <span>@dh.SoDienThoai</span>
                                        <span class="bg-light px-2 py-0 rounded text-uppercase fw-800" style="font-size: 0.65rem;">
                                            @(dh.PhuongThucThanhToan == do_an.Models.PhuongThucThanhToan.ThanhToanOnline ? "Online" : "COD")
                                        </span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(dh.GhiChu))
                                    {
                                        <div class="d-flex align-items-start gap-3 text-muted small fw-500 fst-italic mt-2 bg-light p-2 rounded-3 border-start border-3 border-brand">
                                            <i class="bi bi-chat-left-dots text-brand"></i>
                                            <span>@dh.GhiChu</span>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="col-lg-5">
                                <div class="text-lg-end">
                                    <div class="text-muted small fw-600 mb-1">
                                        @dh.ChiTietDonHangs?.Sum(c => c.SoLuong) sản phẩm
                                    </div>
                                    <div class="h4 fw-800 text-brand mb-1" style="letter-spacing: -1px;">
                                        @dh.TongThanhToan.ToString("N0")đ
                                    </div>
                                    @if (dh.TienGiam > 0)
                                    {
                                        <div class="text-success small fw-800">
                                            <i class="bi bi-patch-check-fill me-1"></i>Đã tiết kiệm @dh.TienGiam.ToString("N0")đ
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        @* ── Timeline theo dõi trạng thái ── *@
                        @{
                            var steps = new (string label, string icon, DateTime? time, bool active, string colorClass)[]
                            {
                                ("Đặt hàng",     "bi-cart-check",  dh.NgayDat,        true, "text-brand"),
                                ("Thanh toán",    "bi-cash-coin",   dh.NgayThanhToan,  dh.NgayThanhToan.HasValue, "text-brand"),
                                ("Chuẩn bị",      "bi-box-seam",    dh.NgayChuanBi,    dh.NgayChuanBi.HasValue, "text-info"),
                                ("Đang giao",     "bi-truck",       dh.NgayBatDauGiao, dh.NgayBatDauGiao.HasValue, "text-info"),
                                ("Đã giao",       "bi-check2-all",  dh.NgayGiao,       dh.NgayGiao.HasValue, "text-success"),
                            };
                            var isCancelled = dh.TrangThai == do_an.Models.TrangThaiDonHang.DaHuy;
                        }
                        <div class="mt-4 pt-3 border-top">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <i class="bi bi-signpost-2 text-brand"></i>
                                <span class="fw-800 small text-dark text-uppercase" style="letter-spacing: 0.5px;">Tiến trình đơn hàng</span>
                            </div>
                            @if (isCancelled)
                            {
                                <div class="d-flex align-items-center gap-3 p-3 rounded-4 bg-danger-soft">
                                    <div class="timeline-dot bg-danger text-white">
                                        <i class="bi bi-x-lg"></i>
                                    </div>
                                    <div>
                                        <div class="fw-800 small text-danger">Đơn hàng đã bị hủy</div>
                                        @if (dh.NgayHuy.HasValue)
                                        {
                                            <div class="text-muted fw-600" style="font-size: 0.7rem;">@dh.NgayHuy.Value.ToString("dd/MM/yyyy HH:mm")</div>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="timeline-track d-flex align-items-start justify-content-between position-relative">
                                    <div class="timeline-line"></div>
                                    @foreach (var (label, icon, time, active, colorClass) in steps)
                                    {
                                        <div class="timeline-step text-center @(active ? "" : "opacity-35")">
                                            <div class="timeline-dot @(active ? "bg-brand text-white shadow-brand" : "bg-light text-muted border")">
                                                <i class="bi @icon"></i>
                                            </div>
                                            <div class="fw-800 mt-2 @(active ? colorClass : "text-muted")" style="font-size: 0.7rem;">@label</div>
                                            @if (time.HasValue)
                                            {
                                                <div class="text-muted fw-600" style="font-size: 0.6rem;">@time.Value.ToString("dd/MM HH:mm")</div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    @if (dh.TrangThai == do_an.Models.TrangThaiDonHang.ChoThanhToan ||
                         dh.TrangThai == do_an.Models.TrangThaiDonHang.DaThanhToan)
                    {
                        <div class="p-4 border-top bg-light bg-opacity-25 d-flex gap-3 justify-content-end">
                            @if (dh.TrangThai == do_an.Models.TrangThaiDonHang.ChoThanhToan &&
                                 dh.PhuongThucThanhToan == do_an.Models.PhuongThucThanhToan.ThanhToanOnline)
                            {
                                <a asp-controller="GioHang" asp-action="ThanhToanGiaLap"
                                   asp-route-donHangId="@dh.Id"
                                   class="btn btn-brand rounded-pill px-4 fw-800 text-white shadow-brand transition-all">
                                    <i class="bi bi-credit-card me-2"></i> Thanh toán
                                </a>
                            }
                            
                            @if (dh.TrangThai == do_an.Models.TrangThaiDonHang.ChoThanhToan || dh.TrangThai == do_an.Models.TrangThaiDonHang.DaThanhToan)
                            {
                                <form asp-action="HuyDonHang" method="post" onsubmit="return confirm('Xác nhận hủy đơn @dh.MaDonHang?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="donHangId" value="@dh.Id" />
                                    <button type="submit" class="btn btn-light rounded-pill px-4 fw-800 text-danger border transition-all">
                                        <i class="bi bi-x-circle me-2"></i> Hủy đơn
                                    </button>
                                </form>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<style>
    .order-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.05) !important;
    }
    .bg-brand-soft { background: #ecfdf5; color: #059669; }
    .bg-warning-soft { background: #fffbeb; color: #d97706; }
    .bg-info-soft { background: #f0f9ff; color: #0284c7; }
    .bg-success-soft { background: #f0fdf4; color: #16a34a; }
    .bg-danger-soft { background: #fef2f2; color: #dc2626; }

    .space-y-4 > *:not(:last-child) { margin-bottom: 2rem; }
    .space-y-2 > *:not(:last-child) { margin-bottom: 0.5rem; }

    /* Timeline */
    .timeline-track {
        padding: 0 8px;
    }
    .timeline-step {
        flex: 1;
        position: relative;
        z-index: 1;
        min-width: 0;
    }
    .timeline-dot {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        transition: all 0.3s ease;
    }
    .timeline-line {
        position: absolute;
        top: 18px;
        left: 10%;
        right: 10%;
        height: 3px;
        background: linear-gradient(90deg, #059669 0%, #e2e8f0 100%);
        border-radius: 2px;
        z-index: 0;
    }
    .opacity-35 {
        opacity: 0.35;
    }
</style>
