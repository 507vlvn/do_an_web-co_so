@model do_an.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Thêm Khách Hàng Mới";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white py-4 px-4 border-0">
                <h5 class="fw-bold mb-0"><i class="bi bi-person-plus-fill text-brand me-2"></i>Thêm Khách Hàng Mới</h5>
            </div>
            <div class="card-body px-4 pb-4">
                <form asp-action="CreateKhachHang" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="TenDangNhap" class="form-label fw-bold small text-muted">Tên Đăng Nhập</label>
                        <input asp-for="TenDangNhap" class="form-control bg-light border-0" required />
                        <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="HoTen" class="form-label fw-bold small text-muted">Họ và Tên</label>
                        <input asp-for="HoTen" class="form-control bg-light border-0" required />
                        <span asp-validation-for="HoTen" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MatKhau" class="form-label fw-bold small text-muted">Mật Khẩu Mặc Định</label>
                        <input asp-for="MatKhau" type="password" value="123456"class="form-control bg-light border-0" required />
                        <span asp-validation-for="MatKhau" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="XacNhanMatKhau" class="form-label fw-bold small text-muted">Xác Nhận Mật Khẩu</label>
                        <input asp-for="XacNhanMatKhau" type="password" value="123456"class="form-control bg-light border-0" required />
                        <span asp-validation-for="XacNhanMatKhau" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SoDienThoai" class="form-label fw-bold small text-muted">Số Điện Thoại</label>
                        <input asp-for="SoDienThoai" class="form-control bg-light border-0" />
                        <span asp-validation-for="SoDienThoai" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-bold small text-muted">Email</label>
                        <input asp-for="Email" type="email" value="null@gmail.com" class="form-control bg-light border-0" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="DiaChi" class="form-label fw-bold small text-muted">Địa Chỉ</label>
                        <textarea asp-for="DiaChi" class="form-control bg-light border-0" rows="2">null</textarea>
                        <span asp-validation-for="DiaChi" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-brand rounded-pill px-4 flex-fill">Tạo Khách Hàng</button>
                        <a asp-action="Index" asp-route-vaiTro="KhachHang" class="btn btn-light rounded-pill px-4">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
