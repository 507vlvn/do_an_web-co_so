@model List<do_an.Models.TaiKhoan>
@{
    ViewData["Title"] = "Quản lý hệ thống tài khoản";
}

<style>
    .role-badge {
        padding: 5px 12px;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .user-avatar-text {
        width: 38px;
        height: 38px;
        background: #f1f5f9;
        color: #475569;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        font-weight: 700;
        border: 1px solid #e2e8f0;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1 text-dark"><i class="bi bi-shield-lock-fill text-brand me-2"></i>Hệ Thống Tài Khoản</h4>
        <p class="text-muted small mb-0">Quản lý người dùng, phân quyền và bảo mật truy cập</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-controller="NhanVien" asp-action="Create" class="btn btn-brand px-4 rounded-pill">
            <i class="bi bi-person-plus-fill me-1"></i> Thêm Nhân Viên
        </a>
    }
    else
    {
        <a asp-controller="TaiKhoan" asp-action="CreateKhachHang" class="btn btn-brand px-4 rounded-pill">
            <i class="bi bi-person-plus-fill me-1"></i> Thêm Khách Hàng
        </a>
    }
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-header bg-white py-4 px-4 border-0">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label small fw-bold text-muted text-uppercase">Tìm kiếm người dùng</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" class="form-control bg-light border-0"
                           placeholder="Tên đăng nhập, Họ tên hoặc Email..."
                           value="@ViewBag.Search" />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Phân quyền</label>
                <select name="vaiTro" class="form-select bg-light border-0" asp-items="ViewBag.VaiTroList">
                    <option value="">-- Tất cả vai trò --</option>
                </select>
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-brand rounded-pill flex-fill">Lọc dữ liệu</button>
                <a asp-action="Index" class="btn btn-light rounded-pill">Xóa lọc</a>
            </div>
        </form>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Người Dùng</th>
                    <th>Email</th>
                    <th class="text-center">Vai Trò</th>
                    <th class="text-center pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tk in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-3">
                                <div class="user-avatar-text">
                                    @(tk.TenDangNhap.Length > 0 ? tk.TenDangNhap[0].ToString().ToUpper() : "?")
                                </div>
                                <div>
                                    <div class="fw-bold text-dark">@tk.TenDangNhap</div>
                                    <div class="text-muted small">@tk.HoTen</div>
                                </div>
                            </div>
                        </td>
                        <td class="text-muted small">@(tk.Email ?? "—")</td>
                        <td class="text-center">
                            @switch (tk.VaiTro)
                            {
                                case "Admin":
                                    <span class="role-badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25">
                                        <i class="bi bi-shield-fill me-1"></i> Admin
                                    </span>
                                    break;
                                case "NhanVien":
                                    <span class="role-badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                                        <i class="bi bi-person-badge-fill me-1"></i> Nhân viên
                                    </span>
                                    break;
                                default:
                                    <span class="role-badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">
                                        <i class="bi bi-person-fill me-1"></i> Khách hàng
                                    </span>
                                    break;
                            }
                        </td>
                        <td class="text-center pe-4">
                            <div class="btn-group">
                                <a asp-action="DoiMatKhau" asp-route-id="@tk.TenDangNhap"
                                   class="btn btn-sm btn-light rounded-circle me-1"
                                   title="Đổi mật khẩu">
                                    <i class="bi bi-key-fill text-warning"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@tk.TenDangNhap"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-light rounded-circle"
                                            title="Xóa tài khoản"
                                            onclick="return confirm('Bạn chắc chắn muốn xóa tài khoản \'@tk.TenDangNhap\'?')">
                                        <i class="bi bi-trash-fill text-danger"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-center py-5">
                            <i class="bi bi-person-x fs-1 text-muted opacity-25 d-block mb-3"></i>
                            <p class="text-muted">Không tìm thấy tài khoản nào.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-white border-0 py-3 px-4">
        <span class="text-muted small">Hiển thị <strong>@Model.Count()</strong> người dùng</span>
    </div>
</div>
