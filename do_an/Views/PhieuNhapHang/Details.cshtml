@model do_an.Models.PhieuNhapHang
@{
    ViewData["Title"] = $"Chi tiet phieu nhap {Model.MaPhieu}";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam"></i> Phieu nhap: @Model.MaPhieu</h2>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lai</a>
</div>


<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5>Thong tin phieu</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-5">Ma phieu:</dt>
                    <dd class="col-sm-7">@Model.MaPhieu</dd>
                    <dt class="col-sm-5">Nha cung cap:</dt>
                    <dd class="col-sm-7">@Model.NhaCungCap?.TenNCC</dd>
                    <dt class="col-sm-5">Nhan vien nhap:</dt>
                    <dd class="col-sm-7">@Model.NhanVienNhap?.HoTen</dd>
                    <dt class="col-sm-5">Ngay nhap:</dt>
                    <dd class="col-sm-7">@Model.NgayNhap.ToString("dd/MM/yyyy HH:mm")</dd>
                    <dt class="col-sm-5">Trang thai:</dt>
                    <dd class="col-sm-7">
                        @switch (Model.TrangThai)
                        {
                            case do_an.Models.TrangThaiPhieuNhap.MoiTao:
                                <span class="badge bg-info">Moi tao</span>
                                break;
                            case do_an.Models.TrangThaiPhieuNhap.DaNhap:
                                <span class="badge bg-success">Da nhap</span>
                                break;
                            case do_an.Models.TrangThaiPhieuNhap.DaHuy:
                                <span class="badge bg-danger">Da huy</span>
                                break;
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5>Tong quan</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-5">Tong tien:</dt>
                    <dd class="col-sm-7"><strong class="text-primary fs-5">@Model.TongTien.ToString("N0") đ</strong></dd>
                    <dt class="col-sm-5">So san pham:</dt>
                    <dd class="col-sm-7">@Model.ChiTietPhieuNhaps.Count loai</dd>
                    <dt class="col-sm-5">Ghi chu:</dt>
                    <dd class="col-sm-7">@(Model.GhiChu ?? "Khong co")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<!-- Chi tiet san pham -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Chi tiet san pham nhap</h5>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>San pham</th>
                    <th class="text-end">So luong</th>
                    <th class="text-end">Gia nhap</th>
                    <th class="text-end">Thanh tien</th>
                    <th>Ma lo</th>
                    <th>HSD</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ct in Model.ChiTietPhieuNhaps)
                {
                    <tr>
                        <td>@ct.SanPham?.TenSanPham</td>
                        <td class="text-end">@ct.SoLuong</td>
                        <td class="text-end">@ct.GiaNhap.ToString("N0") đ</td>
                        <td class="text-end">@((ct.GiaNhap * ct.SoLuong).ToString("N0")) đ</td>
                        <td>@(ct.MaLo ?? "-")</td>
                        <td>@(ct.HanSuDung?.ToString("dd/MM/yyyy") ?? "-")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="table-active">
                    <td colspan="3"><strong>Tong cong</strong></td>
                    <td class="text-end"><strong>@Model.TongTien.ToString("N0") đ</strong></td>
                    <td colspan="2"></td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@if (Model.TrangThai == do_an.Models.TrangThaiPhieuNhap.DaNhap && User.IsInRole("Admin"))
{
    <form asp-action="Huy" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Ban co chac chan huy phieu nhap nay? Ton kho se duoc hoan lai.')">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger"><i class="bi bi-x-circle"></i> Huy phieu nhap (hoan kho)</button>
    </form>
}
