@model do_an.ViewModels.CreatePhieuNhapViewModel
@{
    ViewData["Title"] = "Tạo phiếu nhập hàng mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .create-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04);
        background: #fff;
        border: 1px solid #f1f5f9;
    }
    .form-section-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .form-section-title i {
        color: var(--brand);
    }
    .btn-add-item {
        background-color: rgba(5, 150, 105, 0.08);
        color: var(--brand);
        border: 1px dashed var(--brand);
        font-weight: 600;
        border-radius: 10px;
        padding: 8px 16px;
        transition: all 0.2s;
    }
    .btn-add-item:hover {
        background-color: var(--brand);
        color: #fff;
    }
    .table-modern {
        border-collapse: separate;
        border-spacing: 0 8px;
    }
    .table-modern thead th {
        border: none;
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        padding: 12px 16px;
    }
    .table-modern tbody tr {
        background-color: #f8fafc;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .table-modern tbody tr:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 15px rgba(0, 0, 0, 0.04);
        background-color: #f1f5f9;
    }
    .table-modern tbody td {
        border: none;
        padding: 12px 16px;
        vertical-align: middle;
    }
    .table-modern tbody td:first-child {
        border-top-left-radius: 10px;
        border-bottom-left-radius: 10px;
    }
    .table-modern tbody td:last-child {
        border-top-right-radius: 10px;
        border-bottom-right-radius: 10px;
    }
    .total-box {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        border-radius: 14px;
        padding: 18px 24px;
        box-shadow: 0 10px 20px -5px rgba(5, 150, 105, 0.3);
        min-width: 250px;
    }
    .total-title {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        opacity: 0.85;
        font-weight: 700;
        margin-bottom: 4px;
    }
    .total-amount {
        font-size: 1.8rem;
        font-weight: 800;
    }
    .form-control-modern {
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        padding: 8px 14px;
        font-size: 0.95rem;
        transition: all 0.2s;
    }
    .form-control-modern:focus {
        border-color: var(--brand);
        box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.12);
        background-color: #fff;
    }
    .btn-remove-item {
        background-color: #fee2e2;
        color: #ef4444;
        border: none;
        transition: all 0.2s;
        width: 32px;
        height: 32px;
        padding: 0;
    }
    .btn-remove-item:hover {
        background-color: #ef4444;
        color: #fff;
    }
    .btn-brand-lg {
        background-color: var(--brand);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 12px 28px;
        font-weight: 600;
        transition: all 0.2s;
    }
    .btn-brand-lg:hover {
        background-color: var(--brand-dark);
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(5, 150, 105, 0.2);
    }
    .btn-brand-lg:disabled {
        background-color: #cbd5e1;
        color: #94a3b8;
        transform: none;
        box-shadow: none;
        cursor: not-allowed;
    }
    .btn-cancel-lg {
        border-radius: 10px;
        padding: 12px 28px;
        font-weight: 600;
        background-color: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
        transition: all 0.2s;
    }
    .btn-cancel-lg:hover {
        background-color: #e2e8f0;
        color: #334155;
    }
    hr.dashed {
        border-top: 1px dashed #cbd5e1;
        opacity: 0.6;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1 fw-bold text-slate-800"><i class="bi bi-box-seam-fill text-success"></i> Tạo phiếu nhập hàng</h2>
        <p class="text-muted mb-0">Nhập kho sản phẩm, quản lý lô thuốc và cập nhật số lượng tồn kho tự động.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm px-3 rounded-3"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>


<form asp-action="Create" method="post" id="createForm">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <!-- Metadata Section -->
    <div class="card create-card mb-4 p-4">
        <div class="form-section-title">
            <i class="bi bi-info-circle-fill"></i> Thông tin phiếu nhập
        </div>
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="MaPhieu" class="form-label fw-semibold text-slate-700"></label>
                <input asp-for="MaPhieu" class="form-control form-control-modern bg-light fw-semibold" readonly />
            </div>
            <div class="col-md-4">
                <label asp-for="NhaCungCapId" class="form-label fw-semibold text-slate-700"></label>
                <select asp-for="NhaCungCapId" asp-items="@((List<SelectListItem>)ViewBag.NhaCungCaps)" class="form-select form-control-modern">
                    <option value="">-- Chọn nhà cung cấp --</option>
                </select>
                <span asp-validation-for="NhaCungCapId" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="GhiChu" class="form-label fw-semibold text-slate-700"></label>
                <input asp-for="GhiChu" class="form-control form-control-modern" placeholder="Nhập ghi chú (nếu có)..." />
            </div>
        </div>
    </div>

    <!-- Main Import Section (2 Columns, like POS) -->
    <div class="row g-4 mb-5">
        <!-- LEFT: SIDEBAR SELECT PRODUCT -->
        <div class="col-md-4">
            <div class="card create-card p-4">
                <div class="form-section-title mb-3">
                    <i class="bi bi-plus-circle-fill"></i> Chọn sản phẩm nhập
                </div>

                <!-- Select Product -->
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Tên hoặc mã sản phẩm</label>
                    <select id="selSanPham" class="form-select bg-light border-0 py-2">
                        <option value="">-- Gõ tên sản phẩm để tìm --</option>
                    </select>
                </div>

                <!-- Quantity -->
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Số lượng nhập</label>
                    <div class="input-group">
                        <input id="txtSoLuong" type="number" class="form-control form-control-modern bg-light border-0" min="1" value="1" />
                        <span class="input-group-text bg-light border-0 text-muted" id="lblDvt">đơn vị</span>
                    </div>
                </div>

                <!-- Prices -->
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label small fw-bold text-muted text-uppercase">Giá nhập (VNĐ)</label>
                        <input id="txtGiaNhap" type="number" class="form-control form-control-modern bg-light border-0" min="0" step="500" placeholder="0" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small fw-bold text-muted text-uppercase">Giá bán mới (VNĐ)</label>
                        <input id="txtGiaBan" type="number" class="form-control form-control-modern bg-light border-0" min="0" step="500" placeholder="0" />
                    </div>
                </div>

                <!-- Expiry and Mfg Dates (Drug only) -->
                <div class="row g-3 mb-4" id="divDates" style="display: none;">
                    <div class="col-6">
                        <label class="form-label small fw-bold text-muted text-uppercase text-danger">Ngày sản xuất</label>
                        <input id="txtNgaySX" type="date" class="form-control form-control-modern bg-light border-0" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small fw-bold text-muted text-uppercase text-danger">Hạn sử dụng</label>
                        <input id="txtHanSuDung" type="date" class="form-control form-control-modern bg-light border-0" />
                    </div>
                    <div class="col-12 mt-1">
                        <small class="text-danger"><i class="bi bi-exclamation-circle-fill"></i> Sản phẩm là thuốc. Bắt buộc điền NSX & HSD!</small>
                    </div>
                </div>

                <button type="button" id="btnAddItem" class="btn btn-brand w-100 py-3 rounded-pill fw-bold">
                    <i class="bi bi-plus-circle-fill me-2"></i> THÊM VÀO PHIẾU
                </button>
            </div>
        </div>

        <!-- RIGHT: TABLE OF IMPORT ITEMS -->
        <div class="col-md-8">
            <div class="card create-card p-4 h-100 d-flex flex-column">
                <div class="form-section-title">
                    <i class="bi bi-list-task"></i> Danh sách sản phẩm nhập
                </div>

                <div class="table-responsive flex-grow-1" style="min-height: 250px;">
                    <table class="table table-modern align-middle" id="itemsTable">
                        <thead class="text-muted small text-uppercase">
                            <tr>
                                <th style="width: 40%">Sản phẩm</th>
                                <th class="text-center" style="width: 15%">Số lượng</th>
                                <th class="text-end" style="width: 15%">Giá nhập</th>
                                <th class="text-end" style="width: 15%">Giá bán mới</th>
                                <th class="text-end" style="width: 15%">Thành tiền</th>
                                <th style="width: 5%"></th>
                            </tr>
                        </thead>
                        <tbody id="itemsBody">
                            <tr id="emptyRow">
                                <td colspan="6" class="text-center py-5">
                                    <i class="bi bi-box-seam fs-1 text-muted opacity-25 d-block mb-3"></i>
                                    <p class="text-muted fw-medium mb-0">Chưa có sản phẩm nào được chọn để nhập.</p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <hr class="dashed my-4">

                <!-- Totals & Actions -->
                <div class="row align-items-center mt-auto">
                    <div class="col-md-6">
                        <div class="total-box">
                            <div class="total-title">Tổng tiền thanh toán</div>
                            <div class="total-amount" id="tongTien">0 đ</div>
                        </div>
                    </div>
                    <div class="col-md-6 text-end">
                        <input type="hidden" name="ItemsJson" id="itemsJson" value="[]" />
                        <button type="submit" class="btn btn-brand-lg px-4 py-3 shadow-sm" id="btnSubmit" disabled>
                            <i class="bi bi-check-circle-fill me-2"></i> HOÀN TẤT NHẬP HÀNG
                        </button>
                        <a asp-action="Index" class="btn btn-cancel-lg px-4 py-3 ms-2">Hủy bỏ</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <style>
        .select2-container--bootstrap-5 .select2-selection {
            background-color: #f8f9fa !important;
            border: none !important;
            padding: 6px 4px !important;
            min-height: 42px !important;
            border-radius: 0.375rem !important;
        }
        .select2-container--bootstrap-5 .select2-selection--single .select2-selection__rendered {
            color: #212529;
            line-height: 28px;
        }
        .select2-container--bootstrap-5 .select2-dropdown {
            border: 1px solid #e2e8f0;
            border-radius: 0.5rem;
            box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
        }
        .select2-container--bootstrap-5 .select2-results__option--highlighted[aria-selected] {
            background-color: #059669 !important;
        }
        .select2-container--bootstrap-5 .select2-search--dropdown .select2-search__field {
            border: 1px solid #e2e8f0;
            border-radius: 0.375rem;
            padding: 8px 12px;
        }
    </style>
    <script>
        let items = [];

        // Dữ liệu sản phẩm gồm cả giá nhập và đơn vị tính
        const sanPhams = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.SanPhams));

        $(document).ready(function() {
            // Khởi tạo Select2 cho sản phẩm
            $('#selSanPham').select2({
                theme: 'bootstrap-5',
                placeholder: '-- Gõ tên sản phẩm để tìm kiếm --',
                allowClear: true,
                language: {
                    noResults: function() { return 'Không tìm thấy sản phẩm nào'; },
                    searching: function() { return 'Đang tìm...'; }
                }
            });

            // Nạp option vào Select2
            const selectEl = document.getElementById('selSanPham');
            sanPhams.forEach(s => {
                const opt = document.createElement('option');
                opt.value = s.id;
                opt.textContent = `${s.name} (${s.donViTinh})`;
                selectEl.appendChild(opt);
            });
        });

        // Xử lý khi đổi sản phẩm trong danh sách chọn
        $('#selSanPham').on('change', function() {
            const id = this.value;
            const sp = sanPhams.find(s => s.id == id);
            if (sp) {
                document.getElementById('lblDvt').textContent = sp.donViTinh || 'đơn vị';
                document.getElementById('txtGiaNhap').value = sp.giaNhap;
                
                // Đề xuất giá bán mới = giá nhập + 20%
                if (sp.giaNhap) {
                    const proposeGiaBan = Math.round((parseFloat(sp.giaNhap) * 1.2) / 1000) * 1000;
                    document.getElementById('txtGiaBan').value = proposeGiaBan;
                } else {
                    document.getElementById('txtGiaBan').value = sp.giaBan;
                }

                if (sp.isThuoc) {
                    document.getElementById('divDates').style.display = 'flex';
                } else {
                    document.getElementById('divDates').style.display = 'none';
                    document.getElementById('txtNgaySX').value = '';
                    document.getElementById('txtHanSuDung').value = '';
                }
            } else {
                document.getElementById('lblDvt').textContent = 'đơn vị';
                document.getElementById('txtGiaNhap').value = '';
                document.getElementById('txtGiaBan').value = '';
                document.getElementById('divDates').style.display = 'none';
            }
        });

        // Xử lý tự động đề xuất giá bán khi thay đổi giá nhập
        document.getElementById('txtGiaNhap').addEventListener('input', function() {
            const newGiaNhap = parseFloat(this.value) || 0;
            const currentGiaBan = parseFloat(document.getElementById('txtGiaBan').value) || 0;
            if (newGiaNhap >= currentGiaBan) {
                document.getElementById('txtGiaBan').value = Math.round((newGiaNhap * 1.2) / 1000) * 1000;
            }
        });

        // Thêm sản phẩm vào danh sách nhập
        document.getElementById('btnAddItem').addEventListener('click', function() {
            const sel = document.getElementById('selSanPham');
            const sp = sanPhams.find(s => s.id == sel.value);

            if (!sel.value || !sp) {
                alert('Vui lòng chọn sản phẩm.');
                return;
            }

            const soLuong = parseInt(document.getElementById('txtSoLuong').value) || 0;
            const giaNhap = parseFloat(document.getElementById('txtGiaNhap').value) || 0;
            const giaBan = parseFloat(document.getElementById('txtGiaBan').value) || 0;
            const ngaySX = document.getElementById('txtNgaySX').value || null;
            const hanSuDung = document.getElementById('txtHanSuDung').value || null;

            if (soLuong <= 0) {
                alert('Số lượng nhập phải lớn hơn 0.');
                return;
            }
            if (giaNhap < 0) {
                alert('Giá nhập không được âm.');
                return;
            }
            if (giaBan < 0) {
                alert('Giá bán không được âm.');
                return;
            }

            if (sp.isThuoc) {
                if (!ngaySX || !hanSuDung) {
                    alert('Sản phẩm là thuốc. Vui lòng nhập đầy đủ Ngày sản xuất và Hạn sử dụng.');
                    return;
                }
                const nsx = new Date(ngaySX);
                const hsd = new Date(hanSuDung);
                if (hsd <= nsx) {
                    alert('Hạn sử dụng phải sau Ngày sản xuất.');
                    return;
                }
            }

            // Kiểm tra trùng lặp
            const sanPhamId = parseInt(sel.value);
            const existing = items.find(i => i.sanPhamId === sanPhamId);
            if (existing) {
                alert('Sản phẩm này đã có trong danh sách nhập. Bạn có thể xóa dòng cũ và thêm lại.');
                return;
            }

            items.push({
                sanPhamId: sanPhamId,
                tenSanPham: sp.name,
                donViTinh: sp.donViTinh,
                isThuoc: sp.isThuoc,
                soLuong: soLuong,
                giaNhap: giaNhap,
                giaBan: giaBan,
                ngaySX: ngaySX,
                hanSuDung: hanSuDung
            });

            renderTable();

            // Reset form fields
            $('#selSanPham').val('').trigger('change');
            document.getElementById('txtSoLuong').value = 1;
            document.getElementById('txtGiaNhap').value = '';
            document.getElementById('txtGiaBan').value = '';
            document.getElementById('txtNgaySX').value = '';
            document.getElementById('txtHanSuDung').value = '';
        });

        // Vẽ lại bảng sản phẩm nhập
        function renderTable() {
            const tbody = document.getElementById('itemsBody');
            const emptyRow = document.getElementById('emptyRow');
            const tongTienEl = document.getElementById('tongTien');
            const btnSubmit = document.getElementById('btnSubmit');

            emptyRow.style.display = items.length === 0 ? '' : 'none';
            [...tbody.querySelectorAll('tr:not(#emptyRow)')].forEach(r => r.remove());

            let tongTien = 0;

            items.forEach((item, idx) => {
                const thanhTien = item.soLuong * item.giaNhap;
                tongTien += thanhTien;

                let dateBadges = '';
                if (item.isThuoc) {
                    dateBadges = `
                        <div class="mt-1">
                            <span class="badge bg-light text-primary border me-1"><i class="bi bi-calendar-event"></i> NSX: ${formatDate(item.ngaySX)}</span>
                            <span class="badge bg-light text-danger border me-1"><i class="bi bi-calendar-x"></i> HSD: ${formatDate(item.hanSuDung)}</span>
                        </div>
                    `;
                }

                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>
                        <div class="fw-bold text-dark">${item.tenSanPham}</div>
                        <div class="x-small text-muted">ĐVT: ${item.donViTinh}</div>
                        ${dateBadges}
                    </td>
                    <td class="text-center font-monospace">
                        <span class="fs-6 fw-bold">${item.soLuong}</span>
                    </td>
                    <td class="text-end fw-medium">${formatMoney(item.giaNhap)} đ</td>
                    <td class="text-end fw-medium">${formatMoney(item.giaBan)} đ</td>
                    <td class="text-end fw-bold text-emerald">${formatMoney(thanhTien)} đ</td>
                    <td class="text-center">
                        <button type="button" class="btn btn-sm btn-remove-item rounded-circle" onclick="removeItem(${idx})">
                            <i class="bi bi-trash-fill text-danger"></i>
                        </button>
                    </td>
                `;
                tbody.appendChild(tr);
            });

            tongTienEl.textContent = formatMoney(tongTien) + ' đ';
            document.getElementById('itemsJson').value = JSON.stringify(items);
            btnSubmit.disabled = items.length === 0;
        }

        function removeItem(idx) {
            items.splice(idx, 1);
            renderTable();
        }

        function formatMoney(v) {
            return new Intl.NumberFormat('vi-VN').format(v);
        }

        function formatDate(dateStr) {
            if (!dateStr) return '';
            const d = new Date(dateStr);
            const day = String(d.getDate()).padStart(2, '0');
            const month = String(d.getMonth() + 1).padStart(2, '0');
            const year = d.getFullYear();
            return `${day}/${month}/${year}`;
        }

        // Validate trước khi submit
        document.getElementById('createForm').addEventListener('submit', function (e) {
            if (items.length === 0) {
                e.preventDefault();
                alert('Vui lòng chọn ít nhất 1 sản phẩm.');
                return;
            }
            document.getElementById('itemsJson').value = JSON.stringify(items);
        });
    </script>
}
