@model do_an.Models.DonHang
@{
    ViewData["Title"] = $"Chi Tiết Hóa Đơn #{Model.Id}";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-9">
            <!-- Header & Navigation -->
            <div class="d-flex align-items-center justify-content-between mb-4 gap-3">
                <div>
                    <h4 class="fw-800 text-dark mb-1" style="letter-spacing: -1px;">Chi tiết hóa đơn POS</h4>
                    <p class="text-muted small fw-600 mb-0">Lịch sử giao dịch tại quầy nhà thuốc.</p>
                </div>
                <div class="d-flex gap-2">
                    <button onclick="window.print();" class="btn btn-light rounded-pill px-4 fw-800 text-muted border transition-all d-none d-md-inline-block">
                        <i class="bi bi-printer me-2"></i> In hóa đơn
                    </button>
                    <a asp-action="Index" class="btn btn-light rounded-pill px-4 fw-800 text-muted border transition-all">
                        <i class="bi bi-arrow-left me-2"></i> Quay lại
                    </a>
                </div>
            </div>


            <!-- Receipt Card -->
            <div class="bg-white rounded-5 shadow-sm border overflow-hidden p-0 mb-4 print-no-border" style="border-color: #f1f5f9 !important;">
                <!-- Receipt Top Status -->
                <div class="p-4 p-lg-5 bg-brand-soft border-bottom">
                    <div class="row align-items-center gy-4">
                        <div class="col-md-7">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-brand text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-brand-soft" style="width: 54px; height: 54px;">
                                    <i class="bi bi-receipt fs-3"></i>
                                </div>
                                <div>
                                    <h3 class="fw-800 text-dark mb-0">HÓA ĐƠN #@Model.Id</h3>
                                    <span class="text-brand fw-800 text-uppercase small" style="letter-spacing: 1px;">GIAO DỊCH HOÀN TẤT</span>
                                </div>
                            </div>
                            <div class="d-flex flex-wrap gap-4 mt-4">
                                <div>
                                    <span class="text-muted small fw-800 text-uppercase d-block mb-1" style="letter-spacing: 0.5px;">Thời gian lập</span>
                                    <strong class="text-dark fw-800">@Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>
                                <div class="border-start ps-4">
                                    <span class="text-muted small fw-800 text-uppercase d-block mb-1" style="letter-spacing: 0.5px;">Nhân viên xử lý</span>
                                    @if (Model.NhanVienBan != null)
                                    {
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="bg-white text-brand rounded-circle d-flex align-items-center justify-content-center border" style="width: 28px; height: 28px;">
                                                <span class="small fw-800">@Model.NhanVienBan.HoTen.Substring(0, 1).ToUpper()</span>
                                            </div>
                                            <strong class="text-dark fw-800">@Model.NhanVienBan.HoTen</strong>
                                        </div>
                                    }
                                    else
                                    {
                                        <strong class="text-muted fst-italic">Hệ thống</strong>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="col-md-5 text-md-end">
                            <span class="text-muted small fw-800 text-uppercase d-block mb-2" style="letter-spacing: 0.5px;">Tổng tiền thanh toán</span>
                            <div class="display-5 fw-800 text-brand mb-0" style="letter-spacing: -2px;">
                                @Model.TongThanhToan.ToString("N0") <span class="fs-4">đ</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Table Content -->
                <div class="p-4 p-lg-5">
                    <h5 class="fw-800 text-muted small text-uppercase mb-4 d-flex align-items-center gap-2" style="letter-spacing: 1px;">
                        <i class="bi bi-clipboard2-pulse"></i> Chi tiết đơn thuốc
                    </h5>
                    <div class="table-responsive">
                        <table class="table align-middle table-hover customize-table">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 fw-800 text-muted small text-uppercase">Mã SP</th>
                                    <th class="py-3 fw-800 text-muted small text-uppercase w-40">Tên Sản phẩm</th>
                                    <th class="py-3 fw-800 text-muted small text-uppercase text-center">SL</th>
                                    <th class="py-3 fw-800 text-muted small text-uppercase text-center">ĐVT</th>
                                    <th class="py-3 fw-800 text-muted small text-uppercase text-end">Đơn giá</th>
                                    <th class="pe-4 py-3 fw-800 text-muted small text-uppercase text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody class="border-0">
                                @foreach (var ct in Model.ChiTietDonHangs)
                                {
                                    <tr class="transition-all">
                                        <td class="ps-4 py-4"><code class="fw-800 text-muted">@ct.SanPhamId</code></td>
                                        <td class="py-4">
                                            <div class="fw-800 text-dark">@(ct.TenSanPhamSnapshot ?? ct.SanPham?.TenSanPham ?? "Sản phẩm đã xóa")</div>
                                            @if (!string.IsNullOrEmpty(ct.ThoiDiemUong) || !string.IsNullOrEmpty(ct.CachDung) || ct.SoNgayUong > 0 || !string.IsNullOrEmpty(ct.GhiChuLieuDung))
                                            {
                                                <div class="mt-2 p-3 rounded-4 bg-light border border-dashed text-muted">
                                                    <div class="d-flex flex-wrap gap-2 mb-1">
                                                        @if (!string.IsNullOrEmpty(ct.ThoiDiemUong))
                                                        {
                                                            <span class="badge bg-white text-primary border"><i class="bi bi-clock me-1"></i>@ct.ThoiDiemUong</span>
                                                        }
                                                        @if (!string.IsNullOrEmpty(ct.CachDung))
                                                        {
                                                            <span class="badge bg-white text-success border"><i class="bi bi-play-circle me-1"></i>@ct.CachDung</span>
                                                        }
                                                        @if (ct.SoVienMoiNgay > 0 && ct.SoNgayUong > 0)
                                                        {
                                                            <span class="badge bg-white text-dark border">@ct.SoVienMoiNgay/viên (ngày) × @ct.SoNgayUong ngày</span>
                                                        }
                                                    </div>
                                                    @if (!string.IsNullOrEmpty(ct.GhiChuLieuDung))
                                                    {
                                                        <div class="x-small fst-italic mt-2"><i class="bi bi-chat-left-text me-1"></i>@ct.GhiChuLieuDung</div>
                                                    }
                                                </div>
                                            }
                                        </td>
                                        <td class="py-4 text-center fw-800 text-dark">
                                            @ct.SoLuong
                                        </td>
                                        <td class="py-4 text-center">
                                            <span class="badge bg-info-soft text-info rounded-pill px-3 py-2 fw-800">
                                                @ct.SanPham?.DonViTinh
                                            </span>
                                        </td>
                                        <td class="py-4 text-end fw-600">@ct.GiaBan.ToString("N0")</td>
                                        <td class="pe-4 py-4 text-end fw-800 text-brand fs-5">@ct.ThanhTien.ToString("N0")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="bg-light bg-opacity-50 border-top">
                                <tr>
                                    <td colspan="5" class="ps-4 py-4 text-end fw-800 text-dark h5 mb-0">TỔNG CỘNG</td>
                                    <td class="pe-4 py-4 text-end fw-800 text-brand h4 mb-0" style="letter-spacing: -1.5px;">@Model.TongThanhToan.ToString("N0")đ</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Receipt Actions -->
            <div class="d-flex justify-content-between align-items-center mb-5 px-3">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Delete" asp-route-id="@Model.Id" 
                       class="btn btn-outline-danger rounded-pill px-4 fw-800 transition-all border-opacity-25"
                       onclick="return confirm('Bạn có chắc chắn muốn xóa hóa đơn này khỏi hệ thống lưu trữ?')">
                        <i class="bi bi-trash3 me-2"></i> Xóa hóa đơn
                    </a>
                }
                else
                {
                    <div></div>
                }
                <p class="text-muted small fw-600 mb-0">
                    <i class="bi bi-info-circle me-1 text-brand"></i> Hóa đơn này đã được chốt và cập nhật vào kho dược.
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-brand-soft { background: #ecfdf5; color: #059669; }
    .bg-info-soft { background: #f0f9ff; color: #0284c7; }
    .shadow-brand-soft { box-shadow: 0 4px 15px rgba(5, 150, 105, 0.2); }
    .customize-table tbody tr:hover { background-color: #f8fafc; }
    .w-40 { width: 40%; }
    .smaller { font-size: 0.7rem; }
    
    @@media print {
        .btn, .navbar, .footer, .d-flex.mb-4.gap-3, .alert { display: none !important; }
        body { background: white !important; }
        .container-fluid { padding: 0 !important; }
        .print-no-border { border: none !important; box-shadow: none !important; }
        .bg-brand-soft { background: #f1f5f9 !important; -webkit-print-color-adjust: exact; }
    }
</style>
