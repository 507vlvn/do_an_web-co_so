@model do_an.Models.DonHang
@{
    ViewData["Title"] = $"Xóa Đơn Hàng #{Model.MaDonHang}";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0 fw-bold">
                    <i class="bi bi-exclamation-triangle"></i> Xác Nhận Xóa Đơn Hàng
                </h4>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="bi bi-info-circle"></i>
                    Xóa đơn hàng sẽ có tùy chọn <strong>hoàn lại tồn kho</strong> hoặc <strong>không hoàn kho</strong>.
                </div>

                <table class="table table-bordered">
                    <tr><th class="table-light">Mã Đơn</th><td><span class="badge bg-success">#@Model.MaDonHang</span></td></tr>
                    <tr><th class="table-light">Ngày Đặt</th><td>@Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</td></tr>
                    <tr><th class="table-light">Khách Hàng</th><td>@(Model.HoTenNguoiNhan ?? "—")</td></tr>
                    <tr><th class="table-light">Số Loại Thuốc</th><td>@Model.ChiTietDonHangs.Count</td></tr>
                    <tr><th class="table-light">Tổng Tiền</th><td class="fw-bold text-success">@Model.TongThanhToan.ToString("N0") đ</td></tr>
                </table>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-4 p-3 border rounded bg-light">
                        <label class="fw-bold text-dark mb-2 d-block">Chọn phương thức xóa:</label>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="hoanKho" id="hoanKhoTrue" value="true" checked>
                            <label class="form-check-label fw-bold text-primary" for="hoanKhoTrue">
                                1. Xóa vì lập lỗi (Có hoàn lại tồn kho)
                            </label>
                            <div class="small text-muted">Đơn hàng sẽ bị xóa khỏi hệ thống và số lượng thuốc sẽ được cộng lại vào kho.</div>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="hoanKho" id="hoanKhoFalse" value="false">
                            <label class="form-check-label fw-bold text-danger" for="hoanKhoFalse">
                                2. Xóa vĩnh viễn (Không hoàn kho)
                            </label>
                            <div class="small text-muted">Đơn hàng sẽ bị xóa khỏi hệ thống nhưng số lượng thuốc KHÔNG được cộng lại.</div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash"></i> Xác nhận xóa
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-arrow-left"></i> Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
