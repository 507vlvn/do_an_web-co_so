@model do_an.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Tổng Quan Hệ Thống";
}

<style>
    .dashboard-stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.5rem;
    }
    .glass-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 20px;
        transition: all 0.3s ease;
    }
    .glass-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }
    .section-header-pill {
        display: inline-flex;
        align-items: center;
        padding: 6px 16px;
        background: #f1f5f9;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #64748b;
        margin-bottom: 1rem;
    }
    .chart-wrapper {
        min-height: 380px;
    }
    .alert-indicator {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 8px;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h3 class="fw-bold text-dark mb-1">Chào mừng trở lại, @(User.Identity?.Name ?? "bạn")!</h3>
        <p class="text-muted small mb-0"><i class="bi bi-calendar-event me-1"></i>Hôm nay là @DateTime.Now.ToString("dddd, dd/MM/yyyy")</p>
    </div>
    <div class="d-flex gap-3">
        <a asp-controller="DonThuoc" asp-action="Create" class="btn btn-outline-brand px-4 rounded-pill shadow-sm">
            <i class="bi bi-clipboard2-pulse me-2"></i> Tạo đơn thuốc
        </a>
        <a asp-controller="DonHangPos" asp-action="Create" class="btn btn-brand px-4 rounded-pill shadow-sm">
            <i class="bi bi-plus-lg me-2"></i> Bán Hàng (POS)
        </a>
    </div>
</div>

<!-- SECTION 1: POS & WAREHOUSE (OFFLINE) -->
<div class="section-header-pill"><i class="bi bi-shop-window me-2"></i> Hoạt động tại cửa hàng & Kho</div>
<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card glass-card shadow-sm h-100 border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between mb-3 text-brand">
                    <i class="bi bi-capsule fs-2"></i>
                </div>
                <h6 class="text-muted small fw-bold text-uppercase">Tồn Kho Sản Phẩm</h6>
                <div class="d-flex align-items-end gap-2">
                    <h2 class="fw-bold mb-0">@Model.TotalSanPham</h2>
                    <span class="text-muted small pb-1">mặt hàng</span>
                </div>
                <div class="mt-3">
                    <a asp-controller="SanPham" asp-action="Index" class="text-brand text-decoration-none x-small fw-bold">
                        Quản lý kho <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card glass-card shadow-sm h-100 border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between mb-3 text-primary">
                    <i class="bi bi-receipt-cutoff fs-2"></i>
                </div>
                <h6 class="text-muted small fw-bold text-uppercase">Hóa Đơn POS Hôm Nay</h6>
                <h2 class="fw-bold mb-0">@Model.POSInvoicesToday</h2>
                <div class="mt-3">
                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill x-small">Tổng @Model.TotalPOSInvoices hóa đơn</span>
                </div>
            </div>
        </div>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <div class="col-md-6">
            <div class="card glass-card shadow-sm h-100 border-0 bg-brand-dark text-white" style="background: linear-gradient(135deg, #059669 0%, #065f46 100%);">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <h6 class="text-white-50 small fw-bold text-uppercase">Doanh Thu POS (Tháng @DateTime.Now.Month)</h6>
                        <h1 class="fw-bold mb-3 display-5">@Model.POSRevenueThisMonth.ToString("N0")<span class="fs-4 ms-1">đ</span></h1>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="small"><i class="bi bi-lightning-fill text-warning"></i> Doanh thu hôm nay: <strong>@Model.POSRevenueToday.ToString("N0")đ</strong></div>
                        <i class="bi bi-arrow-up-right-circle fs-3 text-white-50"></i>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- SECTION 2: ONLINE COMMERCE (WEBSITE) -->
<div class="section-header-pill"><i class="bi bi-globe2 me-2"></i> Thương mại điện tử (Online)</div>
<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card glass-card shadow-sm border-0">
            <div class="card-body d-flex align-items-center gap-4 py-4">
                <div class="stat-icon bg-info bg-opacity-10 text-info">
                    <i class="bi bi-box-seam-fill fs-3"></i>
                </div>
                <div>
                    <h3 class="fw-bold mb-0">@Model.TotalSanPham</h3>
                    <p class="text-muted small mb-0 fw-medium">Sản phẩm Website</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card glass-card shadow-sm border-0">
            <div class="card-body d-flex align-items-center gap-4 py-4">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-clock-history fs-3"></i>
                </div>
                <div>
                    <h3 class="fw-bold mb-0">@Model.DonHangChoXuLy</h3>
                    <p class="text-muted small mb-0 fw-medium">Đơn hàng chờ xử lý</p>
                </div>
            </div>
        </div>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <div class="col-md-4">
            <div class="card glass-card shadow-sm border-0 border-end border-4 border-info">
                <div class="card-body d-flex align-items-center gap-4 py-4">
                    <div class="stat-icon bg-success bg-opacity-10 text-success">
                        <i class="bi bi-currency-exchange fs-3"></i>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0">@Model.DoanhThuOnlineThang.ToString("N0")đ</h3>
                        <p class="text-muted small mb-0 fw-medium">Doanh thu Online (Tháng)</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- SECTION 3: ĐƠN THUỐC KÊ ĐƠN -->
<div class="section-header-pill"><i class="bi bi-clipboard2-pulse me-2"></i> Đơn thuốc kê đơn</div>
<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card glass-card shadow-sm border-0">
            <div class="card-body d-flex align-items-center gap-4 py-4">
                <div class="bg-brand-soft text-brand rounded-4 p-3 fs-3">
                    <i class="bi bi-clipboard2-pulse"></i>
                </div>
                <div>
                    <h3 class="fw-bold mb-0">@Model.TotalDonThuoc</h3>
                    <p class="text-muted small mb-0 fw-medium">Tổng đơn thuốc</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card glass-card shadow-sm border-0">
            <div class="card-body d-flex align-items-center gap-4 py-4">
                <div class="bg-warning bg-opacity-10 text-warning rounded-4 p-3 fs-3">
                    <i class="bi bi-hourglass-split"></i>
                </div>
                <div>
                    <h3 class="fw-bold mb-0">@Model.DonThuocChoDuyet</h3>
                    <p class="text-muted small mb-0 fw-medium">Chờ duyệt</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card glass-card shadow-sm border-0">
            <div class="card-body d-flex align-items-center gap-4 py-4">
                <div class="bg-success bg-opacity-10 text-success rounded-4 p-3 fs-3">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div>
                    <h3 class="fw-bold mb-0">@Model.DonThuocDaDuyet</h3>
                    <p class="text-muted small mb-0 fw-medium">Đã duyệt</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card glass-card shadow-sm border-0 border-end border-4 border-info">
            <div class="card-body d-flex align-items-center gap-4 py-4">
                <div class="bg-info bg-opacity-10 text-info rounded-4 p-3 fs-3">
                    <i class="bi bi-shop"></i>
                </div>
                <div>
                    <h3 class="fw-bold mb-0">@Model.DonThuocTrenStore</h3>
                    <p class="text-muted small mb-0 fw-medium">Đang trên Store</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- REVENUE ANALYTICS -->
    @if (User.IsInRole("Admin"))
    {
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white py-4 px-4 border-0">
                    <h6 class="fw-bold mb-0 text-dark">Phân Tích Doanh Thu (7 Ngày Gần Nhất)</h6>
                </div>
                <div class="card-body chart-wrapper">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>
    }
    <!-- PRIORITY ALERTS -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white py-4 px-4 border-0">
                <h6 class="fw-bold mb-0 text-dark text-uppercase small">Cảnh Báo & Thông Báo</h6>
            </div>
            <div class="card-body px-0 py-0">
                <div class="list-group list-group-flush">
                    @if (Model.DonThuocChoDuyet > 0)
                    {
                        <a asp-controller="DonThuoc" asp-action="Index" asp-route-trangThai="0"
                           class="list-group-item list-group-item-action border-0 px-4 py-3 bg-brand-soft">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-dark fw-bold small">
                                    <i class="bi bi-clipboard2-pulse text-brand me-2"></i> Đơn thuốc chờ duyệt
                                </span>
                                <span class="badge bg-brand text-white rounded-pill">@Model.DonThuocChoDuyet</span>
                            </div>
                        </a>
                    }
                    @if (Model.LowStockSanPham.Any())
                    {
                        <div class="px-4 py-3 bg-danger bg-opacity-10 border-start border-4 border-danger mt-2">
                            <h6 class="fw-bold text-danger mb-1 font-size-14">Cảnh báo kho hàng</h6>
                            <p class="text-muted x-small mb-0">Có @Model.LowStockSanPham.Count() loại sản phẩm sắp hết. Cần nhập thêm.</p>
                        </div>
                        @foreach (var t in Model.LowStockSanPham)
                        {
                            <a asp-controller="SanPham" asp-action="Index" class="list-group-item list-group-item-action border-0 px-4 py-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-dark fw-medium small">@t.TenSanPham</span>
                                    <span class="badge bg-soft-danger text-danger">@t.SoLuong @t.DonViTinh</span>
                                </div>
                            </a>
                        }
                    }
                    @if (Model.ExpiringSanPham.Any())
                    {
                        <div class="px-4 py-3 bg-warning bg-opacity-10 border-start border-4 border-warning mt-2">
                            <h6 class="fw-bold text-warning mb-1 font-size-14"><i class="bi bi-exclamation-triangle-fill me-1"></i> Thuốc sắp hết hạn</h6>
                            <p class="text-muted x-small mb-0">Có @Model.ExpiringSanPham.Count() sản phẩm sắp hết hạn sử dụng trong 60 ngày tới.</p>
                        </div>
                        @foreach (var sp in Model.ExpiringSanPham)
                        {
                            <a asp-controller="SanPham" asp-action="Edit" asp-route-id="@sp.Id" class="list-group-item list-group-item-action border-0 px-4 py-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-dark fw-medium small">@sp.TenSanPham</span>
                                    <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill">@sp.HanSuDung!.Value.ToString("dd/MM/yyyy")</span>
                                </div>
                            </a>
                        }
                    }
                    @if (Model.ExpiringLoThuoc.Any())
                    {
                        <div class="px-4 py-3 bg-warning bg-opacity-10 border-start border-4 border-orange mt-2">
                            <h6 class="fw-bold text-warning mb-1 font-size-14"><i class="bi bi-capsule-pill me-1"></i> Lô thuốc sắp hết hạn</h6>
                            <p class="text-muted x-small mb-0">Có @Model.ExpiringLoThuoc.Count() lô thuốc sắp hết hạn trong 60 ngày tới.</p>
                        </div>
                        @foreach (var lo in Model.ExpiringLoThuoc)
                        {
                            <div class="list-group-item border-0 px-4 py-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-dark fw-medium small">@lo.SanPham?.TenSanPham — Lô @lo.MaLo</span>
                                    <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill">@lo.HanSuDung.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
            <div class="card-footer bg-light border-0 text-center py-3">
                <small class="text-muted fw-bold text-uppercase x-small">Trung tâm điều hành Plus</small>
            </div>
        </div>
    </div>
</div>

<!-- LATEST ORDERS TABLE -->
<div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
    <div class="card-header bg-white py-4 px-4 border-0 d-flex justify-content-between align-items-center">
        <h6 class="fw-bold mb-0 text-dark">Đơn Hàng Online Mới Nhất</h6>
        <a asp-controller="DonHangOnline" asp-action="Index" class="btn btn-sm btn-light rounded-pill px-3">Xem tất cả</a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Mã Đơn</th>
                    <th>Khách Hàng</th>
                    <th class="text-end">Giá Trị</th>
                    <th class="text-center">Trạng Thái</th>
                    <th class="text-center pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dh in Model.DonHangMoiNhat)
                {
                    var statusClass = dh.TrangThai switch
                    {
                        do_an.Models.TrangThaiDonHang.ChoThanhToan => "warning",
                        do_an.Models.TrangThaiDonHang.DaThanhToan  => "primary",
                        do_an.Models.TrangThaiDonHang.DangChuanBi  => "info",
                        do_an.Models.TrangThaiDonHang.DangGiao     => "info",
                        do_an.Models.TrangThaiDonHang.DaGiao       => "success",
                        _                                           => "danger"
                    };
                    <tr>
                        <td class="ps-4">
                            <span class="fw-bold text-brand">@dh.MaDonHang</span>
                        </td>
                        <td>
                            <div class="fw-semibold text-dark">@dh.HoTenNguoiNhan</div>
                            <div class="text-muted x-small">@dh.SoDienThoai</div>
                        </td>
                        <td class="text-end fw-bold text-brand">@dh.TongThanhToan.ToString("N0")đ</td>
                        <td class="text-center">
                            <span class="badge bg-@statusClass bg-opacity-10 text-@statusClass px-3 py-1 rounded-pill x-small fw-bold">
                                @dh.TrangThai.ToString()
                            </span>
                        </td>
                        <td class="text-center pe-4">
                            <a asp-controller="DonHangOnline" asp-action="Details" asp-route-id="@dh.Id" class="btn btn-sm btn-light rounded-circle">
                                <i class="bi bi-eye-fill text-brand"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- LATEST ĐƠN THUỐC TABLE -->
<div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
    <div class="card-header bg-white py-4 px-4 border-0 d-flex justify-content-between align-items-center">
        <h6 class="fw-bold mb-0 text-dark"><i class="bi bi-clipboard2-pulse text-brand me-2"></i>Đơn Thuốc Kê Đơn Mới Nhất</h6>
        <a asp-controller="DonThuoc" asp-action="Index" class="btn btn-sm btn-light rounded-pill px-3">Xem tất cả</a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Mã Đơn</th>
                    <th>Tên Đơn Thuốc</th>
                    <th class="text-center">Danh Mục</th>
                    <th class="text-center">Số Thuốc</th>
                    <th class="text-center">Trạng Thái</th>
                    <th class="text-center">Store</th>
                    <th class="text-center pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dt in Model.DonThuocMoiNhat)
                {
                    var dtStatusClass = dt.TrangThai switch
                    {
                        do_an.Models.TrangThaiDonThuoc.MoiTao  => "warning",
                        do_an.Models.TrangThaiDonThuoc.DaDuyet => "success",
                        do_an.Models.TrangThaiDonThuoc.DaMua   => "info",
                        do_an.Models.TrangThaiDonThuoc.DaHuy   => "danger",
                        _                                       => "secondary"
                    };
                    var dtStatusText = dt.TrangThai switch
                    {
                        do_an.Models.TrangThaiDonThuoc.MoiTao  => "Mới tạo",
                        do_an.Models.TrangThaiDonThuoc.DaDuyet => "Đã duyệt",
                        do_an.Models.TrangThaiDonThuoc.DaMua   => "Đã mua",
                        do_an.Models.TrangThaiDonThuoc.HetHan  => "Hết hạn",
                        do_an.Models.TrangThaiDonThuoc.DaHuy   => "Đã hủy",
                        _                                       => dt.TrangThai.ToString()
                    };
                    <tr>
                        <td class="ps-4">
                            <span class="badge bg-brand-soft text-brand rounded-pill px-3 py-2 fw-bold">@dt.MaDonThuoc</span>
                        </td>
                        <td>
                            <div class="fw-semibold text-dark">@dt.TenDonThuoc</div>
                            @if (!string.IsNullOrEmpty(dt.GhiChu))
                            {
                                <div class="text-muted x-small">@(dt.GhiChu.Length > 40 ? dt.GhiChu[..40] + "…" : dt.GhiChu)</div>
                            }
                        </td>
                        <td class="text-center">
                            <span class="text-muted fst-italic small">—</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark rounded-pill px-3 py-1 fw-bold">@dt.ChiTietDonThuocs.Count</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-@dtStatusClass bg-opacity-10 text-@dtStatusClass px-3 py-1 rounded-pill x-small fw-bold">
                                @dtStatusText
                            </span>
                        </td>
                        <td class="text-center">
                            @if (dt.DaDangStore)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-2 py-1 fw-bold">
                                    <i class="bi bi-shop"></i> Online
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-center pe-4">
                            <a asp-controller="DonThuoc" asp-action="Details" asp-route-id="@dt.Id" class="btn btn-sm btn-light rounded-circle">
                                <i class="bi bi-eye-fill text-brand"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.DonThuocMoiNhat.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">
                            <i class="bi bi-clipboard2-x me-2"></i> Chưa có đơn thuốc nào.
                            <a asp-controller="DonThuoc" asp-action="Create" class="text-brand fw-bold ms-2">Tạo đơn đầu tiên</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    @if (User.IsInRole("Admin"))
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const ctx = document.getElementById('revenueChart').getContext('2d');
                const labels = @Html.Raw(ViewBag.ChartLabels ?? "[]");
                const data = @Html.Raw(ViewBag.ChartData ?? "[]");

                const gradient = ctx.createLinearGradient(0, 0, 0, 400);
                gradient.addColorStop(0, 'rgba(5, 150, 105, 0.2)');
                gradient.addColorStop(1, 'rgba(5, 150, 105, 0)');

                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Doanh thu ngày',
                            data: data,
                            borderColor: '#059669',
                            borderWidth: 4,
                            backgroundColor: gradient,
                            fill: true,
                            tension: 0.4,
                            pointBackgroundColor: '#fff',
                            pointBorderColor: '#059669',
                            pointBorderWidth: 2,
                            pointRadius: 5,
                            pointHoverRadius: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: '#1e293b',
                                padding: 12,
                                titleFont: { size: 14 },
                                bodyFont: { size: 16, weight: 'bold' },
                                displayColors: false,
                                callbacks: {
                                    label: function(context) {
                                        return context.parsed.y.toLocaleString() + ' đ';
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: '#f1f5f9' },
                                ticks: {
                                    callback: function(value) {
                                        return (value / 1000000).toFixed(1) + 'M';
                                    }
                                }
                            },
                            x: { grid: { display: false } }
                        }
                    }
                });
            });
        </script>
    }
}