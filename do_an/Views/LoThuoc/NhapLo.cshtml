@model do_an.ViewModels.NhapLoThuocViewModel
@{
    ViewData["Title"] = "Nhập lô thuốc mới";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" asp-route-sanPhamId="@Model.SanPhamId" class="btn btn-outline-secondary btn-sm me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0 text-dark">
            <i class="bi bi-plus-square-fill text-success me-2"></i>Nhập lô thuốc mới
        </h4>
        <p class="text-muted small mb-0">Nhập lô hàng cho thuốc đã có, khác ngày sản xuất / hạn sử dụng</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="NhapLo" method="post">
                    @Html.AntiForgeryToken()

                    @* Chọn thuốc *@
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Thuốc</label>

                        @* Hidden input thực sự submit ID *@
                        <input type="hidden" asp-for="SanPhamId" id="hiddenSanPhamId" />

                        @* Text input tìm kiếm *@
                        <input type="text" id="txtTimThuoc" list="sanPhamDatalist"
                               class="form-control form-control-lg"
                               placeholder="🔍 Gõ tên thuốc / sản phẩm để tìm..."
                               autocomplete="off" />

                        @* Datalist chứa tất cả sản phẩm *@
                        <datalist id="sanPhamDatalist">
                            @if (ViewBag.SanPhamList != null)
                            {
                                foreach (var item in (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.SanPhamList)
                                {
                                    <option value="@item.Text" data-id="@item.Value"></option>
                                }
                            }
                        </datalist>

                        <span asp-validation-for="SanPhamId" class="text-danger small"></span>
                        <div class="form-text text-muted">Gõ để tìm, chọn từ gợi ý để xác nhận.</div>
                    </div>

                    @* Panel thông tin thuốc (hiện khi chọn) *@
                    <div id="thuocInfoPanel" class="mb-3 d-none">
                        <div class="card border-success border-opacity-25 bg-success bg-opacity-10">
                            <div class="card-body py-3 px-4">
                                <div class="row align-items-center g-3">
                                    <div class="col-md-6">
                                        <div class="small text-muted mb-1">Tồn kho hiện tại</div>
                                        <div class="fs-4 fw-bold text-success">
                                            <span id="infoSoLuong">—</span>
                                            <span id="infoDonViTinh" class="fs-6 text-muted fw-normal ms-1"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="small text-muted mb-1">Số lô đang có</div>
                                        <div id="infoLoCount" class="fw-semibold text-dark">—</div>
                                    </div>
                                </div>
                                @* Danh sách lô hiện có *@
                                <div id="infoLoList" class="mt-3 d-none">
                                    <div class="small text-muted fw-semibold mb-2">Các lô đang còn hàng:</div>
                                    <div class="table-responsive">
                                        <table class="table table-sm table-bordered mb-0 bg-white rounded">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Mã lô</th>
                                                    <th class="text-center">SL khả dụng</th>
                                                    <th class="text-center">Hạn SD</th>
                                                </tr>
                                            </thead>
                                            <tbody id="infoLoTableBody"></tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MaLo" class="form-label fw-semibold"></label>
                        <input asp-for="MaLo" class="form-control" placeholder="VD: LO-20250601-001" />
                        <span asp-validation-for="MaLo" class="text-danger small"></span>
                        <div class="form-text">Mã lô phải duy nhất cho mỗi thuốc.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SoLuongNhap" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="SoLuongNhap" type="number" min="1" class="form-control" placeholder="Nhập số lượng..." />
                            <span class="input-group-text" id="unitLabel">đơn vị</span>
                        </div>
                        <span asp-validation-for="SoLuongNhap" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="NgaySX" class="form-label fw-semibold"></label>
                            <input asp-for="NgaySX" type="date" class="form-control" />
                            <span asp-validation-for="NgaySX" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="HanSuDung" class="form-label fw-semibold"></label>
                            <input asp-for="HanSuDung" type="date" class="form-control" />
                            <span asp-validation-for="HanSuDung" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="alert alert-info small">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Số lượng nhập sẽ được <strong>cộng thêm</strong> vào tổng tồn kho của thuốc.
                        Hệ thống sẽ tự động xuất theo nguyên tắc <strong>FEFO</strong> (lô gần hết hạn xuất trước).
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4">
                            <i class="bi bi-check-lg me-1"></i>Nhập lô
                        </button>
                        <a asp-action="Index" asp-route-sanPhamId="@Model.SanPhamId" class="btn btn-outline-secondary">
                            Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const txtTimThuoc = document.getElementById('txtTimThuoc');
        const hiddenSanPhamId = document.getElementById('hiddenSanPhamId');
        const panel = document.getElementById('thuocInfoPanel');

        // Lấy tất cả option từ datalist để tra ngược tên -> id
        function getIdByName(name) {
            const opts = document.querySelectorAll('#sanPhamDatalist option');
            for (const opt of opts) {
                if (opt.value === name) return opt.dataset.id;
            }
            return null;
        }

        function loadThuocInfo(sanPhamId) {
            if (!sanPhamId) {
                panel.classList.add('d-none');
                document.getElementById('unitLabel').textContent = 'đơn vị';
                return;
            }

            fetch(`/LoThuoc/GetThuocInfo?sanPhamId=${sanPhamId}`)
                .then(r => r.json())
                .then(data => {
                    if (!data) return;

                    document.getElementById('infoSoLuong').textContent = data.soLuong;
                    document.getElementById('infoDonViTinh').textContent = data.donViTinh;
                    document.getElementById('unitLabel').textContent = data.donViTinh || 'đơn vị';

                    const loThuocs = data.loThuocs || [];
                    document.getElementById('infoLoCount').textContent =
                        loThuocs.length > 0 ? `${loThuocs.length} lô` : 'Chưa có lô nào';

                    const tbody = document.getElementById('infoLoTableBody');
                    const loList = document.getElementById('infoLoList');

                    if (loThuocs.length > 0) {
                        tbody.innerHTML = loThuocs.map(l => `
                            <tr>
                                <td><span class="badge bg-secondary">${l.maLo}</span></td>
                                <td class="text-center fw-semibold text-success">${l.soLuongKhaDung}</td>
                                <td class="text-center">${l.hanSuDung}</td>
                            </tr>`).join('');
                        loList.classList.remove('d-none');
                    } else {
                        loList.classList.add('d-none');
                    }

                    panel.classList.remove('d-none');
                });
        }

        // Khi người dùng gõ / chọn từ datalist
        txtTimThuoc.addEventListener('input', function () {
            const id = getIdByName(this.value);
            hiddenSanPhamId.value = id || '';
            loadThuocInfo(id);
        });

        // Tự trigger nếu đã có giá trị sẵn (khi từ trang SanPham click vào)
        if (hiddenSanPhamId.value) {
            // Tìm tên tương ứng để điền vào text box
            const opts = document.querySelectorAll('#sanPhamDatalist option');
            for (const opt of opts) {
                if (opt.dataset.id == hiddenSanPhamId.value) {
                    txtTimThuoc.value = opt.value;
                    break;
                }
            }
            loadThuocInfo(hiddenSanPhamId.value);
        }
    </script>
}
