@model do_an.Models.LoThuoc
@{
    ViewData["Title"] = "Chỉnh sửa lô thuốc";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" asp-route-sanPhamId="@Model.SanPhamId" class="btn btn-outline-secondary btn-sm me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0 text-dark">
            <i class="bi bi-pencil-square text-primary me-2"></i>Chỉnh sửa lô thuốc
        </h4>
        <p class="text-muted small mb-0">Lô: <strong>@Model.MaLo</strong> — Thuốc: <strong>@Model.SanPham?.TenSanPham</strong></p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="SanPhamId" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Thuốc</label>
                        <input type="text" class="form-control" value="@Model.SanPham?.TenSanPham" disabled />
                    </div>

                    <div class="mb-3">
                        <label asp-for="MaLo" class="form-label fw-semibold"></label>
                        <input asp-for="MaLo" class="form-control" />
                        <span asp-validation-for="MaLo" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="SoLuongBanDau" class="form-label fw-semibold"></label>
                            <input asp-for="SoLuongBanDau" type="number" min="1" class="form-control" />
                            <span asp-validation-for="SoLuongBanDau" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="SoLuongKhaDung" class="form-label fw-semibold"></label>
                            <input asp-for="SoLuongKhaDung" type="number" min="0" class="form-control" />
                            <span asp-validation-for="SoLuongKhaDung" class="text-danger small"></span>
                            <div class="form-text">Thay đổi số lượng này sẽ tự động cập nhật tồn kho sản phẩm.</div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="NgaySX" class="form-label fw-semibold"></label>
                            <input asp-for="NgaySX" type="date" class="form-control" />
                            <span asp-validation-for="NgaySX" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="HanSuDung" class="form-label fw-semibold"></label>
                            <input asp-for="HanSuDung" type="date" class="form-control" />
                            <span asp-validation-for="HanSuDung" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="GiaNhap" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="GiaNhap" type="number" step="0.01" class="form-control" />
                                <span class="input-group-text">đ</span>
                            </div>
                            <span asp-validation-for="GiaNhap" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="GiaBan" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="GiaBan" type="number" step="0.01" class="form-control" />
                                <span class="input-group-text">đ</span>
                            </div>
                            <span asp-validation-for="GiaBan" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="TrangThai" class="form-check-input" type="checkbox" />
                        <label asp-for="TrangThai" class="form-check-label fw-semibold">Kích hoạt lô này</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-1"></i>Lưu thay đổi
                        </button>
                        <a asp-action="Index" asp-route-sanPhamId="@Model.SanPhamId" class="btn btn-outline-secondary">
                            Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
