@model List<do_an.Models.LoThuoc>
@{
    ViewData["Title"] = "Quản lý lô thuốc";
    var sanPhamId = ViewBag.SanPhamId as int?;
    var sanPhams = ViewBag.SanPhams as List<do_an.Models.SanPham> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1 text-dark">
            <i class="bi bi-box-seam-fill text-success me-2"></i>Quản lý lô thuốc
        </h4>
        <p class="text-muted small mb-0">Theo dõi lô thuốc theo ngày sản xuất &amp; hạn sử dụng. Lô mới được tạo tự động qua <strong>Phiếu Nhập Hàng</strong>.</p>
    </div>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin"))
        {
            <form asp-action="DongBoHanSuDung" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary rounded-pill"
                        onclick="return confirm('Đồng bộ HSD tất cả sản phẩm theo lô FEFO hiện tại?')">
                    <i class="bi bi-arrow-repeat me-1"></i>Đồng bộ HSD
                </button>
            </form>
        }
    </div>
</div>


@* Bộ lọc *@
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end" autocomplete="off">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Lọc theo thuốc</label>
                <select name="sanPhamId" id="selSanPham" class="form-select">
                    <option value="">-- Tất cả sản phẩm --</option>
                    @foreach (var sp in sanPhams)
                    {
                        <option value="@sp.Id" selected="@(sanPhamId == sp.Id ? "selected" : null)">@sp.TenSanPham</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Tìm mã lô </label>
                <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-custom-sm" placeholder="Nhập mã lô hoặc tên thuốc..." autocomplete="off" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-custom-sm w-100">
                    <i class="bi bi-search me-1"></i>Tìm
                </button>
            </div>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string) || sanPhamId.HasValue)
            {
                <div class="col-md-2">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-custom-sm w-100">
                        <i class="bi bi-x-circle me-1"></i>Xóa lọc
                    </a>
                </div>
            }
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã lô</th>
                        <th>Thuốc</th>
                        <th class="text-center">SL ban đầu</th>
                        <th class="text-center">SL khả dụng</th>
                        <th class="text-end">Giá nhập</th>
                        <th class="text-end">Giá bán</th>
                        <th class="text-center">Ngày SX</th>
                        <th class="text-center">Hạn SD</th>
                        <th class="text-center">Còn hạn</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="11" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-4 d-block mb-2"></i>Chưa có lô thuốc nào.
                            </td>
                        </tr>
                    }
                    @foreach (var lo in Model)
                    {
                        var conHan = lo.HanSuDung > DateTime.Today;
                        var sapHetHan = lo.HanSuDung <= DateTime.Today.AddMonths(3) && conHan;
                        var soNgayConLai = (lo.HanSuDung - DateTime.Today).Days;
                        <tr class="@(!lo.TrangThai ? "table-secondary" : sapHetHan ? "table-warning" : "")">
                             <td><span class="badge bg-secondary">@lo.MaLo</span></td>
                            <td>
                                <a asp-action="Index" asp-route-sanPhamId="@lo.SanPhamId" class="text-decoration-none fw-semibold">
                                    @lo.SanPham?.TenSanPham
                                </a>
                            </td>
                            <td class="text-center">@lo.SoLuongBanDau</td>
                            <td class="text-center">
                                @if (lo.SoLuongKhaDung == 0)
                                {
                                    <span class="badge bg-danger">Hết</span>
                                }
                                else
                                {
                                    <span class="fw-semibold text-success">@lo.SoLuongKhaDung</span>
                                }
                            </td>
                            <td class="text-end text-muted small">@lo.GiaNhap.ToString("N0") đ</td>
                            <td class="text-end fw-semibold">@lo.GiaBan.ToString("N0") đ</td>
                            <td class="text-center">@lo.NgaySX.ToString("dd/MM/yyyy")</td>
                            <td class="text-center">@lo.HanSuDung.ToString("dd/MM/yyyy")</td>
                            <td class="text-center">
                                @if (!conHan)
                                {
                                    <span class="badge bg-danger"><i class="bi bi-exclamation-triangle-fill me-1"></i>Đã hết hạn</span>
                                }
                                else if (sapHetHan)
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-clock-history me-1"></i>Còn @soNgayConLai ngày</span>
                                }
                                else
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Còn @soNgayConLai ngày</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (lo.TrangThai)
                                {
                                    <span class="badge bg-success">Đang dùng</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Vô hiệu</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@lo.Id" class="btn btn-outline-primary btn-sm me-1">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="ToggleTrangThai" asp-route-id="@lo.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(lo.TrangThai ? "btn-outline-warning" : "btn-outline-success") me-1"
                                                onclick="return confirm('@(lo.TrangThai ? "Vô hiệu hóa lô này?" : "Kích hoạt lại lô này?")')">
                                            <i class="bi @(lo.TrangThai ? "bi-pause-circle" : "bi-play-circle")"></i>
                                        </button>
                                    </form>
                                    @if (lo.SoLuongKhaDung > 0 || !conHan)
                                    {
                                        <form asp-action="TieuHuy" asp-route-id="@lo.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Tiêu hủy lô @lo.MaLo (@lo.SoLuongKhaDung SP)? Hành động này không thể hoàn tác!')"
                                                    title="Tiêu hủy lô">
                                                <i class="bi bi-fire"></i>
                                            </button>
                                        </form>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <style>
        .select2-container--bootstrap-5 .select2-selection {
            background-color: #fff !important;
            border: 1px solid #cbd5e1 !important;
            border-radius: 0.375rem !important;
            height: 38px !important;
            display: flex !important;
            align-items: center !important;
        }
        .select2-container--bootstrap-5 .select2-selection--single .select2-selection__rendered {
            color: #1e293b;
            line-height: 38px !important;
            font-size: 0.875rem !important;
            padding-left: 8px !important;
        }
        .select2-container--bootstrap-5 .select2-dropdown {
            border: 1px solid #e2e8f0;
            border-radius: 0.5rem;
            box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
        }
        .select2-container--bootstrap-5 .select2-results__option--highlighted[aria-selected] {
            background-color: #059669 !important;
        }
        .select2-container--bootstrap-5 .select2-search--dropdown .select2-search__field {
            border: 1px solid #e2e8f0;
            border-radius: 0.375rem;
            padding: 6px 12px;
        }
        .form-control-custom-sm {
            height: 38px !important;
            border: 1px solid #cbd5e1 !important;
            border-radius: 0.375rem !important;
            font-size: 0.875rem !important;
            padding: 6px 12px !important;
            background-color: #fff !important;
            color: #1e293b !important;
        }
        .form-control-custom-sm:focus {
            border-color: #059669 !important;
            box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.12) !important;
            outline: 0 !important;
        }
        .btn-custom-sm {
            height: 38px !important;
            border-radius: 0.375rem !important;
            font-size: 0.875rem !important;
            font-weight: 500 !important;
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center !important;
        }
    </style>
    <script>
        $(document).ready(function() {
            $('#selSanPham').select2({
                theme: 'bootstrap-5',
                placeholder: '-- Tất cả sản phẩm --',
                allowClear: true,
                language: {
                    noResults: function() { return 'Không tìm thấy sản phẩm nào'; },
                    searching: function() { return 'Đang tìm...'; }
                }
            });

            // Tự động submit khi thay đổi lựa chọn sản phẩm
            $('#selSanPham').on('change', function() {
                $(this).closest('form').submit();
            });
        });
    </script>
}
