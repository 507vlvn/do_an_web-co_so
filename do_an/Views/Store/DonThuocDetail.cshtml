@model do_an.Models.DonThuoc
@{
    ViewData["Title"] = Model.TenDonThuoc;
    Layout = "_StoreLayout";
    decimal tongGiaTri = Model.ChiTietDonThuocs.Sum(c => (c.SoVienMoiNgay * c.SoNgayUong) * (c.SanPham?.GiaBan ?? 0));
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb small fw-bold mb-0">
            <li class="breadcrumb-item"><a asp-controller="Store" asp-action="Index" class="text-decoration-none text-muted">Cửa hàng</a></li>
            <li class="breadcrumb-item active text-brand">@Model.TenDonThuoc</li>
        </ol>
    </nav>

    <div class="row g-5">
        <!-- LEFT: Thông tin đơn thuốc -->
        <div class="col-lg-8">
            <div class="bg-white rounded-5 shadow-sm border overflow-hidden" style="border-color: #f1f5f9 !important;">
                <!-- Header -->
                <div class="p-4 p-lg-5" style="background: linear-gradient(135deg, #ecfdf5, #d1fae5);">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="bg-brand text-white rounded-circle d-flex align-items-center justify-content-center shadow" style="width:50px;height:50px;">
                            <i class="bi bi-clipboard2-pulse fs-4"></i>
                        </div>
                        <div>
                            <h3 class="fw-800 text-dark mb-0">@Model.TenDonThuoc</h3>
                            <span class="badge bg-brand text-white rounded-pill px-3 py-1 fw-bold mt-1">@Model.MaDonThuoc</span>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.GhiChu))
                    {
                        <div class="bg-white bg-opacity-75 rounded-4 p-3 mt-3">
                            <i class="bi bi-chat-left-text text-brand me-2"></i>
                            <span class="fw-600 text-dark">@Model.GhiChu</span>
                        </div>
                    }
                </div>

                <!-- Danh sách thuốc -->
                <div class="p-4 p-lg-5">
                    <h5 class="fw-800 text-dark mb-4">
                        <i class="bi bi-capsule text-brand me-2"></i> Chi tiết đơn thuốc
                        <span class="badge bg-light text-muted rounded-pill ms-2 fw-800">@Model.ChiTietDonThuocs.Count thuốc</span>
                    </h5>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 fw-800 text-muted small text-uppercase">Tên thuốc</th>
                                    <th class="py-3 fw-800 text-muted small text-uppercase text-center">Liều dùng</th>
                                    <th class="py-3 fw-800 text-muted small text-uppercase text-center">Số ngày</th>
                                    <th class="py-3 fw-800 text-muted small text-uppercase text-center">Tổng</th>
                                    <th class="py-3 fw-800 text-muted small text-uppercase text-end pe-4">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ct in Model.ChiTietDonThuocs)
                                {
                                    var tongVien = ct.SoVienMoiNgay * ct.SoNgayUong;
                                    var gia = ct.SanPham?.GiaBan ?? 0;
                                    var thanhTien = tongVien * gia;
                                    var coSanPham = ct.SanPham != null && ct.SanPham.TrenKe && ct.SanPham.SoLuong > 0;

                                    <tr>
                                        <td class="ps-4 py-3">
                                            <div class="fw-800 text-dark">@(ct.SanPham?.TenSanPham ?? ct.TenSanPhamSnapshot ?? "Sản phẩm đã xóa")</div>
                                            <div class="text-muted small">@ct.SanPham?.DonViTinh — ID: @ct.SanPhamId</div>
                                            @if (!coSanPham)
                                            {
                                                <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-2 py-1 mt-1" style="font-size:0.65rem;">
                                                    Chỉ bán tại quầy
                                                </span>
                                            }
                                        </td>
                                        <td class="py-3 text-center">
                                            <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3 py-2 fw-800">
                                                @ct.SoVienMoiNgay viên/ngày
                                            </span>
                                            @if (!string.IsNullOrEmpty(ct.ThoiDiemUong))
                                            {
                                                <div class="mt-1">
                                                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-2 py-1" style="font-size:0.65rem;">
                                                         @ct.ThoiDiemUong
                                                    </span>
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(ct.CachDung))
                                            {
                                                <div class="mt-1">
                                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-2 py-1" style="font-size:0.65rem;">
                                                         @ct.CachDung
                                                    </span>
                                                </div>
                                            }
                                        </td>
                                        <td class="py-3 text-center fw-800">@ct.SoNgayUong ngày</td>
                                        <td class="py-3 text-center">
                                            <span class="badge bg-light text-dark rounded-pill px-3 py-2 fw-800">@tongVien viên</span>
                                        </td>
                                        <td class="py-3 text-end pe-4 fw-800 text-brand">@thanhTien.ToString("N0")đ</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="border-top bg-light bg-opacity-50">
                                <tr>
                                    <td colspan="4" class="ps-4 py-3 text-end fw-800 text-dark">TỔNG LIỆU TRÌNH</td>
                                    <td class="py-3 text-end pe-4 fw-800 text-brand fs-5">@tongGiaTri.ToString("N0")đ</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT: Sidebar mua hàng -->
        <div class="col-lg-4">
            <div class="bg-white rounded-5 shadow-sm border p-4 sticky-top" style="border-color: #f1f5f9 !important; top: 100px;">
                <h5 class="fw-800 text-dark mb-3">
                    <i class="bi bi-cart-check text-brand me-2"></i> Mua theo đơn
                </h5>
                <div class="mb-3 pb-3 border-bottom">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted fw-600">Số loại thuốc</span>
                        <span class="fw-800">@Model.ChiTietDonThuocs.Count</span>
                    </div>
                </div>
                <div class="mb-4">
                    <span class="text-muted small fw-800 text-uppercase">Tổng giá trị liệu trình</span>
                    <div class="fs-3 fw-800 text-brand">@tongGiaTri.ToString("N0")đ</div>
                </div>

                @{
                    // Kiểm tra tất cả thuốc có SanPham tương ứng không
                    bool tatCaCoSanPham = Model.ChiTietDonThuocs.All(c => c.SanPham != null && c.SanPham.TrenKe && c.SanPham.SoLuong > 0);
                    int soThieuOnline = Model.ChiTietDonThuocs.Count(c => c.SanPham == null || !c.SanPham.TrenKe || c.SanPham.SoLuong <= 0);
                }

                @if (tatCaCoSanPham)
                {
                    <form asp-controller="GioHang" asp-action="MuaTheoDon" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="donThuocId" value="@Model.Id" />
                        <button type="submit" class="btn btn-brand w-100 py-3 rounded-4 fw-800 shadow-sm fs-6">
                            <i class="bi bi-cart-plus-fill me-2"></i> THÊM TẤT CẢ VÀO GIỎ
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn btn-secondary w-100 py-3 rounded-4 fw-800" disabled>
                        <i class="bi bi-exclamation-triangle me-2"></i> @soThieuOnline thuốc chưa có trên Store
                    </button>
                    <p class="text-muted small mt-2 mb-0 text-center">
                        Một số thuốc trong đơn chỉ bán tại quầy. Vui lòng liên hệ nhà thuốc.
                    </p>
                }

                <div class="mt-4 pt-3 border-top text-center">
                    <a asp-controller="Store" asp-action="Index" class="text-brand fw-bold text-decoration-none small">
                        <i class="bi bi-arrow-left me-1"></i> Tiếp tục mua sắm
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
