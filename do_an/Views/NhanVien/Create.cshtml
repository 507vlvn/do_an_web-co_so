@model do_an.ViewModels.NhanVienCreateViewModel
@{
    ViewData["Title"] = "Thêm nhân viên mới";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Header -->
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h4 class="fw-800 text-dark mb-1" style="letter-spacing: -1px;">Quản lý nhân sự</h4>
                    <p class="text-muted small fw-600 mb-0">Thêm nhân viên mới vào hệ thống vận hành nhà thuốc.</p>
                </div>
                <a asp-controller="TaiKhoan" asp-action="Index" asp-route-vaiTro="NhanVien" class="btn btn-light rounded-pill px-4 fw-800 text-muted border transition-all">
                    <i class="bi bi-arrow-left me-2"></i> Quay lại
                </a>
            </div>

            <div class="bg-white rounded-5 shadow-sm border p-0 overflow-hidden" style="border-color: #f1f5f9 !important;">
                <form asp-action="Create" method="post" class="p-0">
                    @Html.AntiForgeryToken()
                    
                    <div class="p-4 p-lg-5">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 border-0 shadow-sm px-4 py-3 mb-5 small fw-600" style="background: #fef2f2; color: #991b1b;"></div>
                        }

                        <div class="row g-5">
                            <!-- Section: Personal Info -->
                            <div class="col-lg-6">
                                <h5 class="fw-800 text-brand mb-4 d-flex align-items-center">
                                    <span class="bg-brand-soft rounded-3 p-2 me-3"><i class="bi bi-person-badge"></i></span>
                                    Thông tin cá nhân
                                </h5>
                                <div class="space-y-4">
                                    <div class="row g-3">
                                        <div class="col-md-5">
                                            <label asp-for="MaNV" class="form-label fw-800 text-muted small text-uppercase mb-2" style="letter-spacing: 0.5px;"></label>
                                            <input asp-for="MaNV" class="form-control rounded-4 py-3 bg-light border-0 shadow-none fw-800" placeholder="VD: NV001" />
                                            <span asp-validation-for="MaNV" class="text-danger small mt-1 fw-bold"></span>
                                        </div>
                                        <div class="col-md-7">
                                            <label asp-for="HoTen" class="form-label fw-800 text-muted small text-uppercase mb-2" style="letter-spacing: 0.5px;"></label>
                                            <input asp-for="HoTen" class="form-control rounded-4 py-3 bg-light border-0 shadow-none fw-600" placeholder="Họ và tên đầy đủ"
                                                   oninput="suggestUsername(this.value)" />
                                            <span asp-validation-for="HoTen" class="text-danger small mt-1 fw-bold"></span>
                                        </div>
                                    </div>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label asp-for="BoPhan" class="form-label fw-800 text-muted small text-uppercase mb-2" style="letter-spacing: 0.5px;"></label>
                                            <input asp-for="BoPhan" class="form-control rounded-4 py-3 bg-light border-0 shadow-none fw-600" placeholder="VD: Dược sĩ, Bác sĩ..." />
                                        </div>
                                        <div class="col-md-6">
                                            <label asp-for="VaiTro" class="form-label fw-800 text-muted small text-uppercase mb-2" style="letter-spacing: 0.5px;"></label>
                                            <select asp-for="VaiTro" class="form-select rounded-4 py-3 bg-light border-0 shadow-none fw-600">
                                                <option value="NhanVien">Nhân viên (Dược sĩ tại quầy)</option>
                                                <option value="BacSi">Bác sĩ (Kê đơn mẫu)</option>
                                            </select>
                                            <span asp-validation-for="VaiTro" class="text-danger small mt-1 fw-bold"></span>
                                        </div>
                                    </div>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label asp-for="HeSoLuong" class="form-label fw-800 text-muted small text-uppercase mb-2" style="letter-spacing: 0.5px;"></label>
                                            <input asp-for="HeSoLuong" class="form-control rounded-4 py-3 bg-light border-0 shadow-none fw-800" type="number" step="0.1" min="0" />
                                            <span asp-validation-for="HeSoLuong" class="text-danger small mt-1 fw-bold"></span>
                                        </div>
                                        <div class="col-md-6">
                                            <label asp-for="LuongTheoGio" class="form-label fw-800 text-muted small text-uppercase mb-2" style="letter-spacing: 0.5px;"></label>
                                            <div class="input-group">
                                                <input asp-for="LuongTheoGio" class="form-control rounded-start-4 py-3 bg-light border-0 shadow-none fw-800" type="number" min="0" />
                                                <span class="input-group-text rounded-end-4 bg-light border-0 fw-800 text-muted px-3">đ/h</span>
                                            </div>
                                            <span asp-validation-for="LuongTheoGio" class="text-danger small mt-1 fw-bold"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Section: Account Settings -->
                            <div class="col-lg-6">
                                <h5 class="fw-800 text-brand mb-4 d-flex align-items-center">
                                    <span class="bg-brand-soft rounded-3 p-2 me-3"><i class="bi bi-shield-lock"></i></span>
                                    Tài khoản bảo mật
                                </h5>
                                <div class="space-y-4">
                                    <div>
                                        <label asp-for="TenDangNhap" class="form-label fw-800 text-muted small text-uppercase mb-2" style="letter-spacing: 0.5px;"></label>
                                        <input asp-for="TenDangNhap" class="form-control rounded-4 py-3 bg-light border-0 shadow-none fw-800" id="txtUsername"
                                               placeholder="VD: nhanvien01" />
                                        <span asp-validation-for="TenDangNhap" class="text-danger small mt-1 fw-bold"></span>
                                        <div class="mt-2 small fw-600 text-muted"><i class="bi bi-info-circle me-1"></i> Tên dùng để đăng nhập hệ thống.</div>
                                    </div>
                                    <div>
                                        <label asp-for="Email" class="form-label fw-800 text-muted small text-uppercase mb-2" style="letter-spacing: 0.5px;"></label>
                                        <input asp-for="Email" class="form-control rounded-4 py-3 bg-light border-0 shadow-none fw-600" placeholder="Email liên hệ (Tùy chọn)" />
                                    </div>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label asp-for="MatKhau" class="form-label fw-800 text-muted small text-uppercase mb-2" style="letter-spacing: 0.5px;"></label>
                                            <input asp-for="MatKhau" type="password" class="form-control rounded-4 py-3 bg-light border-0 shadow-none fw-600" />
                                            <span asp-validation-for="MatKhau" class="text-danger small mt-1 fw-bold"></span>
                                        </div>
                                        <div class="col-md-6">
                                            <label asp-for="XacNhanMatKhau" class="form-label fw-800 text-muted small text-uppercase mb-2" style="letter-spacing: 0.5px;"></label>
                                            <input asp-for="XacNhanMatKhau" type="password" class="form-control rounded-4 py-3 bg-light border-0 shadow-none fw-600" />
                                            <span asp-validation-for="XacNhanMatKhau" class="text-danger small mt-1 fw-bold"></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="mt-5 p-4 bg-brand-soft bg-opacity-10 rounded-4 border border-brand border-opacity-25 border-dashed">
                                    <div class="d-flex align-items-center gap-3">
                                         <i class="bi bi-magic fs-3 text-brand"></i>
                                         <p class="small fw-600 text-muted mb-0">
                                            <strong class="text-brand">Gợi ý thông minh:</strong> Hệ thống sẽ tự động đề xuất tên đăng nhập dựa trên họ tên khi bạn nhập liệu.
                                         </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Footer Actions -->
                    <div class="p-4 bg-light bg-opacity-50 border-top d-flex justify-content-end gap-3 px-lg-5">
                        <button type="submit" class="btn btn-brand rounded-pill px-5 py-3 fw-800 text-white shadow-brand"
                                style="background: linear-gradient(135deg, var(--brand-light), var(--brand)); border: none;">
                            <i class="bi bi-person-plus me-2 fs-5"></i> THIẾT LẬP NHÂN VIÊN
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .space-y-4 > *:not(:last-child) { margin-bottom: 1.5rem; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function suggestUsername(hoTen) {
            const field = document.getElementById('txtUsername');
            if (field.value !== '') return;
            const parts = hoTen.trim().toLowerCase().normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '').replace(/đ/g, 'd')
                .split(/\s+/);
            if (parts.length > 1)
                field.value = parts[parts.length - 1] + parts[0][0];
        }
    </script>
}
