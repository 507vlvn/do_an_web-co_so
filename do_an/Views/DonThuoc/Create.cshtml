@model do_an.ViewModels.CreateDonThuocViewModel
@using do_an.Models
@{
    ViewData["Title"] = "Tạo Đơn thuốc kê đơn";
    var sanPhams = ViewBag.SanPhams as IEnumerable<SanPham> ?? new List<SanPham>();
    var danhMucs = ViewBag.DanhMucs as IEnumerable<DanhMucSanPham> ?? new List<DanhMucSanPham>();
}

<style>
    .pos-container { display: flex; gap: 24px; min-height: calc(100vh - 180px); }
    .pos-sidebar { flex: 0 0 400px; }
    .pos-main { flex: 1; }
    .bill-card { background: #fff; border-radius: 20px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); display: flex; flex-direction: column; }
    .bill-header { background: #f8fafc; border-bottom: 1px dashed #e2e8f0; padding: 24px; border-radius: 20px 20px 0 0; }
    .bill-body { flex: 1; padding: 12px 24px; }
    .bill-footer { background: #f8fafc; border-top: 1px dashed #e2e8f0; padding: 24px; border-radius: 0 0 20px 20px; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold text-dark mb-1"><i class="bi bi-clipboard2-pulse text-brand me-2"></i>Tạo đơn thuốc kê đơn</h3>
        <p class="text-muted small mb-0">Tạo đơn thuốc mẫu — có thể tái sử dụng và đăng lên Store</p>
    </div>
    <a asp-action="Index" class="btn btn-light rounded-pill px-4">
        <i class="bi bi-arrow-left me-2"></i> Quay lại danh sách
    </a>
</div>

<form asp-action="Create" method="post" id="formDonThuoc" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" name="ItemsJson" id="itemsJson" value="[]" />

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger rounded-4 border-0 mb-4" role="alert"></div>
    }

    <div class="pos-container">
        <!-- LEFT: SIDEBAR -->
        <div class="pos-sidebar">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-brand text-white py-3 border-0">
                    <h6 class="fw-bold mb-0"><i class="bi bi-capsule-pill me-2"></i> Cấu hình đơn thuốc</h6>
                </div>
                <div class="card-body p-4">
                    <!-- Tên đơn thuốc -->
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase">Tên đơn thuốc</label>
                        <input type="text" name="TenDonThuoc" value="@Model.TenDonThuoc"
                               class="form-control bg-light border-0 py-2"
                               placeholder="VD: Đơn cảm cúm, Đơn viêm họng..." required />
                    </div>

                    <!-- Danh mục Store -->
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase">Danh mục (khi đăng Store)</label>
                        <select name="DanhMucId" class="form-select bg-light border-0 py-2">
                            <option value="">-- Chọn danh mục --</option>
                            @foreach (var dm in danhMucs)
                            {
                                <option value="@dm.Id" selected="@(Model.DanhMucId == dm.Id)">@dm.TenDanhMuc</option>
                            }
                        </select>
                    </div>

                    <!-- Đăng lên Store ngay -->
                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="DangNgayLenStore" value="true" id="chkDangStore" checked />
                            <label class="form-check-label fw-bold small" for="chkDangStore">
                                <i class="bi bi-shop text-brand me-1"></i> Đăng lên Store ngay sau khi tạo
                            </label>
                        </div>
                        <small class="text-muted d-block mt-1">Bật = tự động duyệt & đăng lên Store. Tắt = cần duyệt thủ công.</small>
                    </div>

                    <!-- Hình ảnh đơn thuốc -->
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase">Hình ảnh đơn thuốc</label>
                        <input type="file" name="HinhAnhFile" accept="image/*" class="form-control bg-light border-0"
                               id="inputHinhAnh" onchange="previewImage(this)" />
                        <div id="imgPreview" class="mt-2 d-none">
                            <img id="imgPreviewSrc" src="" alt="Preview"
                                 class="rounded-4 shadow-sm" style="max-height:150px; object-fit:contain;" />
                            <button type="button" class="btn btn-sm btn-outline-danger ms-2 rounded-pill"
                                    onclick="clearPreview()">
                                <i class="bi bi-x"></i> Xóa
                            </button>
                        </div>
                        <small class="text-muted d-block mt-1">Ảnh sẽ hiện trên card đơn thuốc ở Store.</small>
                    </div>

                    <!-- Ghi chú -->
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase">Ghi chú / Lời dặn</label>
                        <textarea name="GhiChu" rows="2" class="form-control bg-light border-0"
                                  placeholder="Uống sau ăn, tránh rượu bia...">@Model.GhiChu</textarea>
                    </div>

                    <hr class="my-3" />

                    <!-- Chọn thuốc -->
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase">Tìm & Chọn thuốc</label>
                        <select id="selThuoc" class="form-select bg-light border-0 py-2">
                            <option value="">-- Gõ tên thuốc hoặc mã --</option>
                            @foreach (var sp in sanPhams)
                            {
                                <option value="@sp.Id"
                                        data-ten="@sp.TenSanPham"
                                        data-gia="@sp.GiaBan"
                                        data-soluong="@sp.SoLuong"
                                        data-donvi="@sp.DonViTinh">
                                    @sp.TenSanPham (@sp.DonViTinh) — Còn @sp.SoLuong
                                </option>
                            }
                        </select>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Sử dụng/Ngày</label>
                            <div class="input-group">
                                <input id="txtSoVien" type="number" class="form-control bg-light border-0" min="1" value="1" />
                                <span class="input-group-text bg-light border-0 text-muted">viên</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Số ngày dùng</label>
                            <div class="input-group">
                                <input id="txtSoNgay" type="number" class="form-control bg-light border-0" min="1" value="1" />
                                <span class="input-group-text bg-light border-0 text-muted">ngày</span>
                            </div>
                        </div>
                    </div>

                    <!-- Thời điểm uống & Cách dùng -->
                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Thời điểm uống</label>
                            <select id="selThoiDiem" class="form-select bg-light border-0 py-2">
                                <option value="">-- Chọn --</option>
                                <option value="Sáng"> Sáng</option>
                                <option value="Trưa"> Trưa</option>
                                <option value="Chiều"> Chiều</option>
                                <option value="Tối"> Tối</option>
                                <option value="Sáng - Tối"> Sáng - Tối</option>
                                <option value="Sáng - Trưa - Tối"> Sáng - Trưa - Tối</option>
                                <option value="Sáng - Trưa - Chiều - Tối">Cả ngày (4 lần)</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Cách dùng</label>
                            <select id="selCachDung" class="form-select bg-light border-0 py-2">
                                <option value="">-- Chọn --</option>
                                <option value="Trước ăn"> Trước ăn</option>
                                <option value="Sau ăn"> Sau ăn</option>
                                <option value="Trong khi ăn">Trong khi ăn</option>
                                <option value="Lúc đói">Lúc đói</option>
                                <option value="Trước khi ngủ"> Trước khi ngủ</option>
                                <option value="Khi cần">Khẩn Cấp</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase">Đơn giá tham khảo</label>
                        <div class="input-group">
                            <input id="txtGiaBan" type="text" class="form-control bg-light border-0 fw-bold text-brand" readonly placeholder="0" />
                            <span class="input-group-text bg-light border-0 text-muted">đ/v</span>
                        </div>
                    </div>

                    <button type="button" id="btnAddItem" class="btn btn-brand w-100 py-3 rounded-pill fw-bold">
                        <i class="bi bi-plus-circle-fill me-2"></i> THÊM VÀO ĐƠN THUỐC
                    </button>
                </div>
            </div>
        </div>

        <!-- RIGHT: BILL -->
        <div class="pos-main">
            <div class="bill-card h-100">
                <div class="bill-header d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold text-dark mb-0">CHI TIẾT ĐƠN THUỐC</h5>
                        <small class="text-muted">Đơn thuốc kê đơn — có thể tái sử dụng</small>
                    </div>
                    <div class="text-end">
                        <div class="text-muted small fw-bold">NGÀY TẠO</div>
                        <div class="fw-bold">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                </div>

                <div class="bill-body">
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="text-muted small text-uppercase">
                                <tr>
                                    <th style="width:40%">Tên thuốc / Mã</th>
                                    <th class="text-center">Liều dùng</th>
                                    <th class="text-center">Thời gian</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end">Thành tiền</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="tbodyItems">
                                <tr id="emptyRow">
                                    <td colspan="6" class="text-center py-5">
                                        <i class="bi bi-clipboard2-x fs-1 text-muted opacity-25 d-block mb-3"></i>
                                        <p class="text-muted fw-medium">Đơn thuốc trống. Vui lòng thêm thuốc.</p>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="bill-footer">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Tổng giá trị tham khảo (VNĐ)</p>
                            <div class="fs-2 fw-800 text-brand" id="tdTotal">0</div>
                        </div>
                        <div class="col-md-6 text-end">
                            <button type="submit" class="btn btn-brand px-5 py-3 rounded-pill fw-bold shadow-sm" id="btnSubmit" disabled>
                                <i class="bi bi-clipboard2-check-fill me-2"></i> LƯU ĐƠN THUỐC
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<style>
    /* Select2 custom styling to match the form design */
    .select2-container--bootstrap-5 .select2-selection {
        background-color: #f8f9fa !important;
        border: none !important;
        padding: 6px 4px !important;
        min-height: 42px !important;
        border-radius: 0.375rem !important;
    }
    .select2-container--bootstrap-5 .select2-selection--single .select2-selection__rendered {
        color: #212529;
        line-height: 28px;
    }
    .select2-container--bootstrap-5 .select2-dropdown {
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
    }
    .select2-container--bootstrap-5 .select2-results__option--highlighted[aria-selected] {
        background-color: #059669 !important;
    }
    .select2-container--bootstrap-5 .select2-search--dropdown .select2-search__field {
        border: 1px solid #e2e8f0;
        border-radius: 0.375rem;
        padding: 8px 12px;
    }
</style>
<script>
    let items = [];

    const selThuoc = document.getElementById('selThuoc');
    const txtSoVien = document.getElementById('txtSoVien');
    const txtSoNgay = document.getElementById('txtSoNgay');
    const txtGiaBan = document.getElementById('txtGiaBan');
    const selThoiDiem = document.getElementById('selThoiDiem');
    const selCachDung = document.getElementById('selCachDung');
    const btnAddItem = document.getElementById('btnAddItem');
    const tbody = document.getElementById('tbodyItems');
    const tdTotal = document.getElementById('tdTotal');
    const itemsJson = document.getElementById('itemsJson');
    const btnSubmit = document.getElementById('btnSubmit');
    const emptyRow = document.getElementById('emptyRow');

    // Initialize Select2 for searchable drug dropdown
    $(document).ready(function() {
        $('#selThuoc').select2({
            theme: 'bootstrap-5',
            placeholder: '-- Gõ tên thuốc hoặc mã để tìm kiếm --',
            allowClear: true,
            language: {
                noResults: function() { return 'Không tìm thấy thuốc nào'; },
                searching: function() { return 'Đang tìm...'; }
            }
        });
    });

    // Select2 fires 'change' on the original select
    $('#selThuoc').on('change', function () {
        const opt = selThuoc.options[selThuoc.selectedIndex];
        if (opt && opt.value) {
            txtGiaBan.value = formatMoney(parseFloat(opt.dataset.gia || 0));
        } else {
            txtGiaBan.value = '';
        }
    });

    btnAddItem.addEventListener('click', function () {
        const opt = selThuoc.options[selThuoc.selectedIndex];
        const soVien = parseInt(txtSoVien.value) || 0;
        const soNgay = parseInt(txtSoNgay.value) || 0;
        const giaBan = parseFloat(opt.dataset.gia || 0);

        if (!selThuoc.value) { alert('Vui lòng chọn thuốc.'); return; }
        if (soVien <= 0) { alert('Số viên mỗi ngày phải > 0.'); return; }
        if (soNgay <= 0) { alert('Số ngày uống phải > 0.'); return; }

        const maThuocInt = parseInt(selThuoc.value);
        const existing = items.find(i => i.maThuoc === maThuocInt);
        if (existing) { alert('Thuốc này đã có trong đơn.'); return; }

        const tongSoVien = soVien * soNgay;
        items.push({
            maThuoc: maThuocInt,
            tenThuoc: opt.dataset.ten,
            soVienMoiNgay: soVien,
            soNgayUong: soNgay,
            tongSoVien: tongSoVien,
            giaBan: giaBan,
            thanhTien: tongSoVien * giaBan,
            thoiDiemUong: selThoiDiem.value || null,
            cachDung: selCachDung.value || null
        });

        renderTable();
        // Reset fields - use Select2 API to reset the dropdown
        $('#selThuoc').val('').trigger('change');
        txtSoVien.value = 1;
        txtSoNgay.value = 1;
        txtGiaBan.value = '';
        selThoiDiem.value = '';
        selCachDung.value = '';
    });

    function renderTable() {
        emptyRow.style.display = items.length === 0 ? '' : 'none';
        [...tbody.querySelectorAll('tr:not(#emptyRow)')].forEach(r => r.remove());

        items.forEach((item, idx) => {
            const thoiDiem = item.thoiDiemUong ? `<div class="x-small text-primary fw-bold">🕐 ${item.thoiDiemUong}</div>` : '';
            const cachDung = item.cachDung ? `<div class="x-small text-success fw-bold">🍽️ ${item.cachDung}</div>` : '';
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>
                    <div class="fw-bold text-dark">${item.tenThuoc}</div>
                    <div class="x-small text-muted">${item.maThuoc}</div>
                </td>
                <td class="text-center">
                    <span class="font-monospace">${item.soVienMoiNgay} viên/ngày</span>
                    ${thoiDiem}${cachDung}
                </td>
                <td class="text-center font-monospace">${item.soNgayUong} ngày</td>
                <td class="text-center"><span class="badge bg-light text-dark border">${item.tongSoVien} viên</span></td>
                <td class="text-end fw-bold text-brand">${formatMoney(item.thanhTien)}</td>
                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-light rounded-circle" onclick="removeItem(${idx})">
                        <i class="bi bi-trash-fill text-danger"></i>
                    </button>
                </td>`;
            tbody.appendChild(tr);
        });

        const total = items.reduce((s, i) => s + i.thanhTien, 0);
        tdTotal.textContent = formatMoney(total);
        itemsJson.value = JSON.stringify(items);
        btnSubmit.disabled = items.length === 0;
    }

    function removeItem(idx) { items.splice(idx, 1); renderTable(); }
    function formatMoney(v) { return new Intl.NumberFormat('vi-VN').format(v); }

    // Preview hình ảnh
    function previewImage(input) {
        const preview = document.getElementById('imgPreview');
        const img = document.getElementById('imgPreviewSrc');
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => { img.src = e.target.result; preview.classList.remove('d-none'); };
            reader.readAsDataURL(input.files[0]);
        }
    }
    function clearPreview() {
        document.getElementById('inputHinhAnh').value = '';
        document.getElementById('imgPreview').classList.add('d-none');
        document.getElementById('imgPreviewSrc').src = '';
    }
</script>
}