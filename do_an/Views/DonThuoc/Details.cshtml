@model do_an.Models.DonThuoc
@using do_an.Models
@{
    ViewData["Title"] = $"Đơn thuốc {Model.MaDonThuoc}";
    var danhMucs = ViewBag.DanhMucs as List<DanhMucSanPham> ?? new List<DanhMucSanPham>();

    var badgeCss = Model.TrangThai switch
    {
        TrangThaiDonThuoc.MoiTao => "bg-warning text-dark",
        TrangThaiDonThuoc.DaDuyet => "bg-success",
        TrangThaiDonThuoc.DaMua => "bg-info",
        TrangThaiDonThuoc.DaHuy => "bg-danger",
        _ => "bg-secondary"
    };
    var trangThaiText = Model.TrangThai switch
    {
        TrangThaiDonThuoc.MoiTao => "Mới tạo",
        TrangThaiDonThuoc.DaDuyet => "Đã duyệt",
        TrangThaiDonThuoc.DaMua => "Đã mua",
        TrangThaiDonThuoc.HetHan => "Hết hạn",
        TrangThaiDonThuoc.DaHuy => "Đã hủy",
        _ => Model.TrangThai.ToString()
    };
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-9">
            <!-- Header -->
            <div class="d-flex align-items-center justify-content-between mb-4 gap-3">
                <div>
                    <h4 class="fw-800 text-dark mb-1" style="letter-spacing:-1px;">Chi tiết đơn thuốc</h4>
                    <p class="text-muted small fw-600 mb-0">Quản lý đơn thuốc kê đơn và đăng lên Store</p>
                </div>
                <a asp-action="Index" class="btn btn-light rounded-pill px-4 fw-800 text-muted border transition-all">
                    <i class="bi bi-arrow-left me-2"></i> Quay lại
                </a>
            </div>


            <!-- Info Card -->
            <div class="bg-white rounded-5 shadow-sm border overflow-hidden mb-4" style="border-color: #f1f5f9 !important;">
                <div class="p-4 p-lg-5 bg-brand-soft border-bottom">
                    <div class="row align-items-center gy-4">
                        <div class="col-md-7">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-brand text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-brand-soft"
                                     style="width:54px;height:54px;">
                                    <i class="bi bi-clipboard2-pulse fs-3"></i>
                                </div>
                                <div>
                                    <h3 class="fw-800 text-dark mb-0">@Model.MaDonThuoc</h3>
                                    <span class="text-brand fw-800 text-uppercase small">@Model.TenDonThuoc</span>
                                </div>
                            </div>
                            <div class="d-flex flex-wrap gap-4 mt-4">
                                <div>
                                    <span class="text-muted small fw-800 text-uppercase d-block mb-1">Trạng thái</span>
                                    <span class="badge @badgeCss rounded-pill px-3 py-2 fw-800">@trangThaiText</span>
                                </div>
                                <div>
                                    <span class="text-muted small fw-800 text-uppercase d-block mb-1">Store</span>
                                    @if (Model.DaDangStore)
                                    {
                                        <span class="badge bg-success rounded-pill px-3 py-2 fw-800"><i class="bi bi-shop me-1"></i> Đang online</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-25 text-muted rounded-pill px-3 py-2 fw-800">Chưa đăng</span>
                                    }
                                </div>
                                <div>
                                    <span class="text-muted small fw-800 text-uppercase d-block mb-1">Danh mục</span>
                                    <strong class="text-dark fw-800">Đơn thuốc kê đơn</strong>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-5 text-md-end">
                            <span class="text-muted small fw-800 text-uppercase d-block mb-2">Tổng giá trị tham khảo</span>
                            @{
                                decimal tongGiaTri = Model.ChiTietDonThuocs.Sum(c => (c.SoVienMoiNgay * c.SoNgayUong) * (c.SanPham?.GiaBan ?? 0));
                            }
                            <div class="display-5 fw-800 text-brand mb-0" style="letter-spacing:-2px;">
                                @tongGiaTri.ToString("N0") <span class="fs-4">đ</span>
                            </div>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.GhiChu))
                {
                    <div class="px-4 px-lg-5 py-3 bg-warning bg-opacity-10 border-bottom">
                        <i class="bi bi-chat-left-text text-warning me-2"></i>
                        <strong class="small text-warning-emphasis">Ghi chú:</strong>
                        <span class="small">@Model.GhiChu</span>
                    </div>
                }

                <!-- Chi tiết thuốc -->
                <div class="p-4 p-lg-5">
                    <h5 class="fw-800 text-muted small text-uppercase mb-4 d-flex align-items-center gap-2" style="letter-spacing:1px;">
                        <i class="bi bi-clipboard2-pulse"></i> Chi tiết đơn thuốc
                    </h5>
                    <div class="table-responsive">
                        <table class="table align-middle table-hover">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 fw-800 text-muted small text-uppercase">Mã thuốc</th>
                                    <th class="py-3 fw-800 text-muted small text-uppercase w-40">Tên thuốc</th>
                                    <th class="py-3 fw-800 text-muted small text-uppercase text-center">Liều lượng</th>
                                    <th class="py-3 fw-800 text-muted small text-uppercase text-center">Số ngày</th>
                                    <th class="py-3 fw-800 text-muted small text-uppercase text-center">Tổng lượng</th>
                                    <th class="py-3 fw-800 text-muted small text-uppercase text-end">Đơn giá</th>
                                    <th class="pe-4 py-3 fw-800 text-muted small text-uppercase text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody class="border-0">
                                @foreach (var ct in Model.ChiTietDonThuocs)
                                {
                                    var tongVien = ct.SoVienMoiNgay * ct.SoNgayUong;
                                    var giaBan = ct.SanPham?.GiaBan ?? 0;
                                    var thanhTien = tongVien * giaBan;

                                    <tr class="transition-all">
                                        <td class="ps-4 py-4"><code class="fw-800 text-muted">ID: @ct.SanPhamId</code></td>
                                        <td class="py-4">
                                            <div class="fw-800 text-dark">@(ct.SanPham?.TenSanPham ?? ct.TenSanPhamSnapshot ?? "Sản phẩm đã xóa")</div>
                                            <div class="text-muted small fw-600">Dạng: @ct.SanPham?.DonViTinh</div>
                                        </td>
                                        <td class="py-4 text-center">
                                            <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3 py-2 fw-800">
                                                @ct.SoVienMoiNgay viên/ngày
                                            </span>
                                        </td>
                                        <td class="py-4 text-center fw-800 text-dark">@ct.SoNgayUong</td>
                                        <td class="py-4 text-center">
                                            <div class="fw-800 text-dark">@tongVien</div>
                                            <div class="text-muted smaller fw-800 text-uppercase">@ct.SanPham?.DonViTinh</div>
                                        </td>
                                        <td class="py-4 text-end fw-600">@giaBan.ToString("N0")</td>
                                        <td class="pe-4 py-4 text-end fw-800 text-brand fs-5">@thanhTien.ToString("N0")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="bg-light bg-opacity-50 border-top">
                                <tr>
                                    <td colspan="6" class="ps-4 py-4 text-end fw-800 text-dark h5 mb-0">TỔNG CỘNG</td>
                                    <td class="pe-4 py-4 text-end fw-800 text-brand h4 mb-0">@tongGiaTri.ToString("N0")đ</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="bg-white rounded-5 shadow-sm border p-4 mb-4" style="border-color: #f1f5f9 !important;">
                <h6 class="fw-800 text-muted small text-uppercase mb-3" style="letter-spacing:1px;">
                    <i class="bi bi-gear me-2"></i> Thao tác
                </h6>
                <div class="d-flex flex-wrap gap-3">
                    @if (Model.TrangThai == TrangThaiDonThuoc.MoiTao)
                    {
                        <form asp-action="Duyet" asp-route-id="@Model.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-success rounded-pill px-4 fw-800"
                                    onclick="return confirm('Duyệt đơn thuốc này?')">
                                <i class="bi bi-check-circle me-2"></i> Duyệt đơn
                            </button>
                        </form>
                    }

                    @if (Model.TrangThai == TrangThaiDonThuoc.DaDuyet)
                    {
                        @if (!Model.DaDangStore)
                        {
                            <!-- Form đăng lên Store -->
                            <form asp-action="DangStore" asp-route-id="@Model.Id" method="post" class="d-inline-flex align-items-center gap-2">
                                @Html.AntiForgeryToken()
                                <select name="danhMucId" class="form-select form-select-sm rounded-pill border fw-600" style="width:200px;">
                                    <option value="">-- Chọn danh mục --</option>
                                    @foreach (var dm in danhMucs)
                                    {
                                        <option value="@dm.Id">@dm.TenDanhMuc</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-info rounded-pill px-4 fw-800 text-white">
                                    <i class="bi bi-shop me-2"></i> Đăng lên Store
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="DangStore" asp-route-id="@Model.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-secondary rounded-pill px-4 fw-800"
                                        onclick="return confirm('Gỡ đơn thuốc này khỏi Store?')">
                                    <i class="bi bi-shop me-2"></i> Gỡ khỏi Store
                                </button>
                            </form>
                        }
                    }

                    @if (Model.TrangThai != TrangThaiDonThuoc.DaHuy)
                    {
                        <form asp-action="Huy" asp-route-id="@Model.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger rounded-pill px-4 fw-800"
                                    onclick="return confirm('Hủy đơn thuốc này?')">
                                <i class="bi bi-x-circle me-2"></i> Hủy đơn
                            </button>
                        </form>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@Model.Id"
                               class="btn btn-outline-danger rounded-pill px-4 fw-800 ms-auto"
                               onclick="return confirm('Xóa vĩnh viễn đơn thuốc này?')">
                            <i class="bi bi-trash3 me-2"></i> Xóa
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>