@model List<do_an.Models.Voucher>
@{
    ViewData["Title"] = "Quản lý voucher";
}

<style>
    .voucher-code {
        padding: 4px 12px;
        background: #f1f5f9;
        border: 1px dashed #cbd5e1;
        border-radius: 6px;
        font-family: 'Courier New', Courier, monospace;
        font-weight: 700;
        color: #0f172a;
        display: inline-block;
    }
    .status-pill {
        padding: 4px 10px;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1 text-dark"><i class="bi bi-ticket-perforated-fill text-brand me-2"></i>Chương Trình Ưu Đãi</h4>
        <p class="text-muted small mb-0">Quản lý mã giảm giá và khuyến mãi toàn hệ thống</p>
    </div>
    <a asp-action="Create" class="btn btn-brand px-4 rounded-pill">
        <i class="bi bi-plus-lg me-1"></i> Tạo Voucher mới
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Mã Voucher</th>
                    <th class="text-center">Ưu đãi (%)</th>
                    <th class="text-end">Giảm tối đa</th>
                    <th class="text-end">Đơn tối thiểu</th>
                    <th>Thời gian áp dụng</th>
                    <th class="text-center">Sử dụng</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in Model)
                {
                    <tr class="@(!v.KichHoat ? "bg-light opacity-75" : "")">
                        <td class="ps-4">
                            <span class="voucher-code">@v.MaVoucher</span>
                        </td>
                        <td class="text-center">
                            <span class="fw-bold text-danger fs-5">@v.PhanTramGiam%</span>
                        </td>
                        <td class="text-end">
                            <span class="fw-semibold text-dark">
                                @(v.GiamToiDa.HasValue ? v.GiamToiDa.Value.ToString("N0") + "đ" : "∞")
                            </span>
                        </td>
                        <td class="text-end text-muted small">@v.DonHangToiThieu.ToString("N0")đ</td>
                        <td class="small text-muted">
                            <div class="d-flex flex-column">
                                <span><i class="bi bi-calendar-check me-1"></i>Từ: @v.NgayBatDau.ToString("dd/MM/yyyy")</span>
                                <span><i class="bi bi-calendar-x me-1"></i>Đến: @v.NgayHetHan.ToString("dd/MM/yyyy")</span>
                            </div>
                        </td>
                        <td class="text-center">
                            @{
                                var usagePercent = (v.SoLanSuDung > 0) ? (v.DaSuDung * 100 / v.SoLanSuDung) : 0;
                                var progressColor = usagePercent > 90 ? "bg-danger" : usagePercent > 50 ? "bg-warning" : "bg-success";
                            }
                            <div class="fw-bold text-dark x-small mb-1">@v.DaSuDung / @v.SoLanSuDung</div>
                            <div class="progress" style="height: 4px; width: 60px; margin: 0 auto;">
                                <div class="progress-bar @progressColor" style="width: @usagePercent%"></div>
                            </div>
                        </td>
                        <td class="text-center">
                            @if (v.ConHieuLuc)
                            {
                                <span class="status-pill bg-success bg-opacity-10 text-success border border-success border-opacity-25">Đang kích hoạt</span>
                            }
                            else if (!v.KichHoat)
                            {
                                <span class="status-pill bg-secondary bg-opacity-25 text-muted border border-secondary border-opacity-25">Vô hiệu hóa</span>
                            }
                            else if (DateTime.Now > v.NgayHetHan)
                            {
                                <span class="status-pill bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25">Đã hết hạn</span>
                            }
                            else
                            {
                                <span class="status-pill bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25">Đã hết lượt</span>
                            }
                        </td>
                        <td class="text-center pe-4">
                            <div class="btn-group">
                                <form asp-action="ToggleKichHoat" asp-route-id="@v.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" 
                                            class="btn btn-sm btn-light rounded-circle me-1" 
                                            title="@(v.KichHoat ? "Tắt voucher" : "Bật voucher")">
                                        <i class="bi bi-@(v.KichHoat ? "pause-fill text-warning" : "play-fill text-success") fs-6"></i>
                                    </button>
                                </form>
                                <form asp-action="Delete" asp-route-id="@v.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-light rounded-circle"
                                            onclick="return confirm('Xóa voucher \'@v.MaVoucher\'?')" title="Xóa">
                                        <i class="bi bi-trash text-danger"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="text-center py-5">
                            <i class="bi bi-ticket-perforated fs-1 text-muted opacity-25 d-block mb-3"></i>
                            <p class="text-muted">Chưa có mã voucher nào được tạo.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
